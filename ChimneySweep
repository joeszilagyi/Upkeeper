#!/usr/bin/env bash
set -euo pipefail

# Scripted issue-fix launcher. Unlike FlameOn, this owns pre-model issue
# ranking and then hands one locked issue to Upkeeper.

ROOT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
UPKEEPER_CMD="${UPKEEPER_CMD:-$ROOT_DIR/Upkeeper}"
source "$ROOT_DIR/lib/upkeeper/launcher_full_burn.bash"
source "$ROOT_DIR/lib/upkeeper/automation_obligations.bash"
upkeeper_launcher_apply_full_burn_defaults
upkeeper_launcher_apply_automation_identity "ChimneySweep" "issue-repair" "own-bug-queue"

CHIMNEYSWEEP_VERBOSITY="${CHIMNEYSWEEP_VERBOSITY:-basic}"
CHIMNEYSWEEP_MODEL_OVERRIDE="${CHIMNEYSWEEP_MODEL_OVERRIDE:-5.5_xhigh}"
CHIMNEYSWEEP_REQUESTED_MODEL=""
CHIMNEYSWEEP_REQUESTED_REASONING_EFFORT=""
CHIMNEYSWEEP_SKIP_LABELS="${CHIMNEYSWEEP_SKIP_LABELS:-in-progress,blocked,duplicate,wontfix,invalid,needs-info,done,merged,has-pr}"
CHIMNEYSWEEP_CLEAN_EXIT_CODE="${CHIMNEYSWEEP_CLEAN_EXIT_CODE:-25}"
CHIMNEYSWEEP_WORKFLOW="${CHIMNEYSWEEP_WORKFLOW:-comment-review-apply}"
CHIMNEYSWEEP_DRY_RUN="${CHIMNEYSWEEP_DRY_RUN:-0}"
CHIMNEYSWEEP_JSON="0"

usage() {
  cat <<EOF
Usage: ${0##*/} [--silent|--basic|--debug1] [--model-override=SPEC] [--model MODEL] [--reasoning-effort EFFORT] [--workflow=comment-review-apply|comment-review|comment|review|apply] [--dry-run] [--json] [--help]

Script one issue-fix Upkeeper cycle:
  - reconcile open Upkeeper automation obligations before GitHub issue ranking
  - list open GitHub issues before any backend Codex process can start
  - if the actionable open queue is clean, print "high five yay" and exit 25
  - prefer security-class issues, then data-integrity-class issues
  - within security/data-integrity, choose the least recently touched issue
  - after those classes are clear, rank the remaining queue by containment
    title/tag signals, severity words, then longest untouched
  - default to a comment -> review -> apply workflow using separate Upkeeper
    backend instantiations for each stage
  - hand the selected issue to every stage as --fix-issue=NUMBER
  - request full pass/module coverage against the locked issue target
  - make comment/review stages source read-only and make apply work the bug
  - fail-closed launcher burn: Lattice required, encrypted pre-contact backup
    required, and workspace-write containment pinned before launch

Flags:
  --silent        Set CODEX_TERMINAL_VERBOSITY=silent
  --basic         Set CODEX_TERMINAL_VERBOSITY=basic (default)
  --debug1        Set CODEX_TERMINAL_VERBOSITY=debug1
  --model-override=SPEC
                  Upkeeper model override, such as 5.5_xhigh or
                  5.3-codex-spark_xhigh
  --model MODEL   Model shortcut converted to a model override
  --reasoning-effort EFFORT
                  Reasoning effort for --model (default: xhigh)
  --workflow=...  Stage workflow: comment-review-apply (default), comment-review,
                  comment, review, or apply
  --dry-run       Print the selected issue and resolved Upkeeper command
  --json          Print the scripted selection JSON before launching
  --help          Show this help

Environment:
  UPKEEPER_CMD                  Upkeeper command path (default: ./Upkeeper)
  CHIMNEYSWEEP_MODEL_OVERRIDE   Upkeeper model override (default: 5.5_xhigh)
  CHIMNEYSWEEP_VERBOSITY        Default verbosity when no flag is given
  CHIMNEYSWEEP_SKIP_LABELS      Comma-separated labels to skip
  CHIMNEYSWEEP_CLEAN_EXIT_CODE  Clean queue exit code (default: 25)
  CHIMNEYSWEEP_WORKFLOW         Default workflow (default: comment-review-apply)
  CHIMNEYSWEEP_DRY_RUN          Set to 1 to print the resolved command
  UPKEEPER_PRECONTACT_BACKUP_AGE_RECIPIENT
                              Required for live encrypted backup full burn
EOF
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --help|-h)
      usage
      exit 0
      ;;
    --silent)
      CHIMNEYSWEEP_VERBOSITY="silent"
      shift
      ;;
    --basic)
      CHIMNEYSWEEP_VERBOSITY="basic"
      shift
      ;;
    --debug1)
      CHIMNEYSWEEP_VERBOSITY="debug1"
      shift
      ;;
    --model-override=*)
      CHIMNEYSWEEP_MODEL_OVERRIDE="${1#--model-override=}"
      [[ -n "$CHIMNEYSWEEP_MODEL_OVERRIDE" ]] || {
        printf 'ChimneySweep: --model-override requires a value\n' >&2
        exit 64
      }
      shift
      ;;
    --model-override)
      [[ $# -ge 2 && -n "${2:-}" ]] || {
        printf 'ChimneySweep: --model-override requires a value\n' >&2
        exit 64
      }
      CHIMNEYSWEEP_MODEL_OVERRIDE="$2"
      shift 2
      ;;
    --model=*)
      CHIMNEYSWEEP_REQUESTED_MODEL="${1#--model=}"
      [[ -n "$CHIMNEYSWEEP_REQUESTED_MODEL" ]] || {
        printf 'ChimneySweep: --model requires a value\n' >&2
        exit 64
      }
      shift
      ;;
    --model)
      [[ $# -ge 2 && -n "${2:-}" ]] || {
        printf 'ChimneySweep: --model requires a value\n' >&2
        exit 64
      }
      CHIMNEYSWEEP_REQUESTED_MODEL="$2"
      shift 2
      ;;
    --reasoning-effort=*)
      CHIMNEYSWEEP_REQUESTED_REASONING_EFFORT="${1#--reasoning-effort=}"
      [[ -n "$CHIMNEYSWEEP_REQUESTED_REASONING_EFFORT" ]] || {
        printf 'ChimneySweep: --reasoning-effort requires a value\n' >&2
        exit 64
      }
      shift
      ;;
    --reasoning-effort)
      [[ $# -ge 2 && -n "${2:-}" ]] || {
        printf 'ChimneySweep: --reasoning-effort requires a value\n' >&2
        exit 64
      }
      CHIMNEYSWEEP_REQUESTED_REASONING_EFFORT="$2"
      shift 2
      ;;
    --dry-run)
      CHIMNEYSWEEP_DRY_RUN="1"
      shift
      ;;
    --workflow=*)
      CHIMNEYSWEEP_WORKFLOW="${1#--workflow=}"
      shift
      ;;
    --workflow)
      printf 'ChimneySweep: use --workflow=comment-review-apply, --workflow=comment-review, --workflow=comment, --workflow=review, or --workflow=apply\n' >&2
      exit 64
      ;;
    --json)
      CHIMNEYSWEEP_JSON="1"
      shift
      ;;
    *)
      printf 'ChimneySweep: unknown argument: %s\n' "$1" >&2
      usage >&2
      exit 64
      ;;
  esac
done

case "$CHIMNEYSWEEP_VERBOSITY" in
  silent|basic|debug1)
    ;;
  *)
    printf 'ChimneySweep: unsupported verbosity: %s\n' "$CHIMNEYSWEEP_VERBOSITY" >&2
    exit 64
    ;;
esac

case "$CHIMNEYSWEEP_CLEAN_EXIT_CODE" in
  ''|*[!0-9]*)
    printf 'ChimneySweep: clean exit code must be numeric: %s\n' "$CHIMNEYSWEEP_CLEAN_EXIT_CODE" >&2
    exit 64
    ;;
esac

case "$CHIMNEYSWEEP_WORKFLOW" in
  staged)
    CHIMNEYSWEEP_WORKFLOW="comment-review-apply"
    ;;
  comment-review-apply|comment-review|comment|review|apply)
    ;;
  *)
    printf 'ChimneySweep: unsupported workflow: %s\n' "$CHIMNEYSWEEP_WORKFLOW" >&2
    exit 64
    ;;
esac
UPKEEPER_AUTOMATION_WORKFLOW="$CHIMNEYSWEEP_WORKFLOW"
export UPKEEPER_AUTOMATION_WORKFLOW

if [[ -n "$CHIMNEYSWEEP_REQUESTED_MODEL" ]]; then
  if ! CHIMNEYSWEEP_MODEL_OVERRIDE="$(upkeeper_launcher_model_override_from_model_effort "$CHIMNEYSWEEP_REQUESTED_MODEL" "${CHIMNEYSWEEP_REQUESTED_REASONING_EFFORT:-xhigh}")"; then
    printf 'ChimneySweep: unsupported model/effort pair: %s %s (supported: gpt-5.5 xhigh, gpt-5.3-codex-spark xhigh)\n' \
      "$CHIMNEYSWEEP_REQUESTED_MODEL" "${CHIMNEYSWEEP_REQUESTED_REASONING_EFFORT:-xhigh}" >&2
    exit 64
  fi
elif [[ -n "$CHIMNEYSWEEP_REQUESTED_REASONING_EFFORT" ]]; then
  printf 'ChimneySweep: --reasoning-effort requires --model\n' >&2
  exit 64
fi

if [[ ! -x "$UPKEEPER_CMD" ]]; then
  printf 'ChimneySweep: Upkeeper command is not executable: %s\n' "$UPKEEPER_CMD" >&2
  exit 127
fi

obligation_json="$(automation_select_open_obligation_json)"
obligation_status="$(automation_json_field "$obligation_json" status)"
if [[ "$obligation_status" == "ok" ]]; then
  obligation_id="$(automation_json_field "$obligation_json" id)"
  obligation_path="$(automation_json_field "$obligation_json" path)"
  obligation_target="$(automation_json_field "$obligation_json" target_file)"
  obligation_repair_target="$(automation_json_field "$obligation_json" repair_target_file)"
  obligation_repair_basis="$(automation_json_field "$obligation_json" repair_target_basis)"
  obligation_repair_detail="$(automation_json_field "$obligation_json" repair_target_detail)"
  obligation_kind="$(automation_json_field "$obligation_json" kind)"
  obligation_summary="$(automation_json_field "$obligation_json" summary)"
  obligation_prompt_file="$(automation_prepare_obligation_prompt_file "$obligation_json")" || {
    printf 'ChimneySweep: failed to prepare automation obligation prompt\n' >&2
    exit 3
  }
  UPKEEPER_AUTOMATION_WORKFLOW="obligation-repair"
  UPKEEPER_AUTOMATION_OBLIGATION_ID="$obligation_id"
  UPKEEPER_AUTOMATION_OBLIGATION_PATH="$obligation_path"
  export UPKEEPER_AUTOMATION_WORKFLOW
  export UPKEEPER_AUTOMATION_OBLIGATION_ID
  export UPKEEPER_AUTOMATION_OBLIGATION_PATH

  args=(
    "--model-override=$CHIMNEYSWEEP_MODEL_OVERRIDE"
    "--prompt-pass=all"
    "--review-modules=p24,p25,p26,p27,p28,p29,p30"
    "--target-file=$obligation_repair_target"
    "--prompt-file"
    "$obligation_prompt_file"
  )

  printf 'ChimneySweep: selected automation obligation %s for repair\n' "$obligation_id" >&2
  printf 'ChimneySweep: obligation kind=%s target=%s summary=%s\n' "$obligation_kind" "$obligation_target" "$obligation_summary" >&2
  if [[ "$obligation_repair_target" != "$obligation_target" ]]; then
    printf 'ChimneySweep: obligation target remapped from %s to %s basis=%s detail=%s\n' \
      "$obligation_target" "$obligation_repair_target" "$obligation_repair_basis" "$obligation_repair_detail" >&2
  fi

  if [[ "$CHIMNEYSWEEP_JSON" == "1" ]]; then
    printf '%s\n' "$obligation_json"
  fi

  if [[ "$CHIMNEYSWEEP_DRY_RUN" == "1" ]]; then
    upkeeper_launcher_print_full_burn_env_prefix
    printf 'CODEX_TERMINAL_VERBOSITY=%q ' "$CHIMNEYSWEEP_VERBOSITY"
    printf '%q' "$UPKEEPER_CMD"
    printf ' %q' "${args[@]}"
    printf '\n'
    exit 0
  fi

  upkeeper_launcher_report_full_burn "ChimneySweep"
  CODEX_TERMINAL_VERBOSITY="$CHIMNEYSWEEP_VERBOSITY" exec "$UPKEEPER_CMD" "${args[@]}"
fi
if [[ "$obligation_status" == "operator_action_required" ]]; then
  obligation_id="$(automation_json_field "$obligation_json" id)"
  obligation_kind="$(automation_json_field "$obligation_json" kind)"
  obligation_summary="$(automation_json_field "$obligation_json" summary)"
  obligation_repair_target="$(automation_json_field "$obligation_json" repair_target_file)"
  obligation_reason="$(automation_json_field "$obligation_json" reason)"
  printf 'ChimneySweep: operator action required before issue repair can continue\n' >&2
  printf 'ChimneySweep: obligation id=%s kind=%s reason=%s\n' "$obligation_id" "$obligation_kind" "$obligation_reason" >&2
  printf 'ChimneySweep: %s\n' "$obligation_summary" >&2
  if [[ -n "$obligation_repair_target" ]]; then
    printf 'ChimneySweep: run %s, then rerun ChimneySweep\n' "$obligation_repair_target" >&2
  fi
  if [[ "$CHIMNEYSWEEP_JSON" == "1" ]]; then
    printf '%s\n' "$obligation_json"
  fi
  exit 75
fi

if ! command -v gh >/dev/null 2>&1; then
  printf 'ChimneySweep: required command missing: gh\n' >&2
  exit 127
fi

selection_json="$(
  python3 - "$CHIMNEYSWEEP_SKIP_LABELS" <<'PY'
import json
import re
import subprocess
import sys
from datetime import datetime, timezone

skip_labels = {item.strip().lower() for item in sys.argv[1].split(",") if item.strip()}


def gh_json(args):
    cp = subprocess.run(["gh", *args], text=True, capture_output=True, check=False)
    if cp.returncode != 0:
        print(json.dumps({"status": "gh_error", "stderr": cp.stderr.strip()}))
        raise SystemExit(0)
    try:
        return json.loads(cp.stdout or "[]")
    except json.JSONDecodeError as exc:
        print(json.dumps({"status": "gh_json_error", "error": str(exc)}))
        raise SystemExit(0)


def labels(issue):
    return [str(label.get("name", "")).strip().lower() for label in issue.get("labels", []) if label.get("name")]


def title(issue):
    return str(issue.get("title", ""))


def issue_class(issue):
    names = set(labels(issue))
    lower_title = title(issue).lower()
    if names & {"security", "sec", "vulnerability"} or re.search(r"\b(sec|security|vulnerab|cve)\b", lower_title):
        return "security"
    if "data-integrity" in names or "data integrity" in lower_title or "integrity" in lower_title:
        return "data-integrity"
    if "bug" in names or re.match(r"^(critical|high|medium-high|medium|low|bug)[: ]", lower_title):
        return "bug"
    return "other"


def normalize_issue_timestamp(raw):
    value = str(raw or "").strip()
    if not value:
        return datetime.min.replace(tzinfo=timezone.utc)
    if value.endswith("Z"):
        value = f"{value[:-1]}+00:00"
    try:
        return datetime.fromisoformat(value).astimezone(timezone.utc)
    except (TypeError, ValueError):
        return datetime.min.replace(tzinfo=timezone.utc)


def severity_rank(issue):
    lower_title = title(issue).lower()
    names = set(labels(issue))
    haystack = " ".join([lower_title, *names])
    if "critical" in haystack:
        return 0
    if re.search(r"\bhigh\b", haystack):
        return 1
    if "medium-high" in haystack or "medium high" in haystack:
        return 2
    if re.search(r"\bmedium\b", haystack):
        return 3
    if re.search(r"\blow\b", haystack):
        return 4
    if lower_title.startswith("need:") or "need" in names:
        return 6
    return 5


def containment_rank(issue):
    lower_title = title(issue).lower()
    names = " ".join(labels(issue))
    haystack = f"{lower_title} {names}"
    containment_words = (
        "containment",
        "security",
        "data protection",
        "llm isolation",
        "runtime",
        "transcript",
        "backup",
        "restore",
        "lattice",
        "integrity",
        "prompt",
        "sandbox",
        "secret",
    )
    return 0 if any(word in haystack for word in containment_words) else 1


def updated(issue):
    return normalize_issue_timestamp(issue.get("updatedAt") or issue.get("createdAt"))


def created(issue):
    return normalize_issue_timestamp(issue.get("createdAt"))


def number(issue):
    try:
        return int(issue.get("number", 0))
    except (TypeError, ValueError):
        return 0


issues = gh_json(
    [
        "issue",
        "list",
        "--state",
        "open",
        "--limit",
        "1000",
        "--json",
        "number,title,url,labels,createdAt,updatedAt,comments",
    ]
)

if not isinstance(issues, list):
    print(json.dumps({"status": "gh_json_error", "error": "issue list did not return a list"}))
    raise SystemExit(0)

candidates = [issue for issue in issues if not (set(labels(issue)) & skip_labels)]

if not candidates:
    print(json.dumps({"status": "clean", "open_count": len(issues), "candidate_count": 0}))
    raise SystemExit(0)

classes = {item: [] for item in ("security", "data-integrity", "bug", "other")}
for issue in candidates:
    classes[issue_class(issue)].append(issue)

if classes["security"]:
    selected = sorted(classes["security"], key=lambda issue: (updated(issue), created(issue), number(issue)))[0]
    basis = "security class first; least recently touched"
elif classes["data-integrity"]:
    selected = sorted(classes["data-integrity"], key=lambda issue: (updated(issue), created(issue), number(issue)))[0]
    basis = "data-integrity class after security clear; least recently touched"
else:
    selected = sorted(
        classes["bug"] + classes["other"],
        key=lambda issue: (
            containment_rank(issue),
            severity_rank(issue),
            updated(issue),
            created(issue),
            title(issue).lower(),
            number(issue),
        ),
    )[0]
    basis = "general queue ranked by containment signal, severity, then least recently touched"

print(
    json.dumps(
        {
            "status": "ok",
            "number": str(selected.get("number", "")),
            "title": title(selected),
            "url": str(selected.get("url", "")),
            "labels": ",".join(label.get("name", "") for label in selected.get("labels", []) if label.get("name")),
            "class": issue_class(selected),
            "selection_basis": basis,
            "created_at": created(selected).isoformat(),
            "updated_at": updated(selected).isoformat(),
            "open_count": len(issues),
            "candidate_count": len(candidates),
        }
    )
)
PY
)"

selection_status="$(
  python3 - "$selection_json" <<'PY'
import json
import sys
print(json.loads(sys.argv[1]).get("status", "unknown"))
PY
)"

if [[ "$CHIMNEYSWEEP_JSON" == "1" ]]; then
  printf '%s\n' "$selection_json"
fi

case "$selection_status" in
  clean)
    printf 'ChimneySweep: open issue queue clean; high five yay\n'
    exit "$CHIMNEYSWEEP_CLEAN_EXIT_CODE"
    ;;
  ok)
    ;;
  gh_error|gh_json_error)
    printf 'ChimneySweep: issue listing failed: %s\n' "$selection_json" >&2
    exit 3
    ;;
  *)
    printf 'ChimneySweep: issue selection failed: %s\n' "$selection_json" >&2
    exit 3
    ;;
esac

issue_number="$(
  python3 - "$selection_json" <<'PY'
import json
import sys
print(json.loads(sys.argv[1]).get("number", ""))
PY
)"

[[ -n "$issue_number" ]] || {
  printf 'ChimneySweep: selected issue was missing a number: %s\n' "$selection_json" >&2
  exit 3
}

args=(
  "--model-override=$CHIMNEYSWEEP_MODEL_OVERRIDE"
  "--prompt-pass=all"
  "--review-modules=p24,p25,p26,p27,p28,p29,p30"
  "--fix-issue=$issue_number"
)

case "$CHIMNEYSWEEP_WORKFLOW" in
  comment-review-apply)
    workflow_stages=(comment review apply)
    ;;
  comment-review)
    workflow_stages=(comment review)
    ;;
  comment)
    workflow_stages=(comment)
    ;;
  review)
    workflow_stages=(review)
    ;;
  apply)
    workflow_stages=(apply)
    ;;
esac

printf 'ChimneySweep: selected issue #%s for repair\n' "$issue_number" >&2
python3 - "$selection_json" <<'PY' >&2
import json
import sys
data = json.loads(sys.argv[1])
print(f"ChimneySweep: class={data.get('class', 'unknown')} updated_at={data.get('updated_at', 'unknown')} basis={data.get('selection_basis', 'unknown')}")
print(f"ChimneySweep: title={data.get('title', '')}")
PY
printf 'ChimneySweep: workflow=%s stages=%s\n' "$CHIMNEYSWEEP_WORKFLOW" "$(IFS=,; printf '%s' "${workflow_stages[*]}")" >&2

if [[ "$CHIMNEYSWEEP_DRY_RUN" == "1" ]]; then
  for workflow_stage in "${workflow_stages[@]}"; do
    upkeeper_launcher_print_full_burn_env_prefix
    printf 'CODEX_TERMINAL_VERBOSITY=%q ' "$CHIMNEYSWEEP_VERBOSITY"
    printf '%q' "$UPKEEPER_CMD"
    printf ' %q' "${args[@]}" "--issue-workflow-stage=$workflow_stage"
    printf '\n'
  done
  exit 0
fi

upkeeper_launcher_report_full_burn "ChimneySweep"
for workflow_stage in "${workflow_stages[@]}"; do
  printf 'ChimneySweep: starting workflow stage=%s issue=%s\n' "$workflow_stage" "$issue_number" >&2
  CODEX_TERMINAL_VERBOSITY="$CHIMNEYSWEEP_VERBOSITY" "$UPKEEPER_CMD" "${args[@]}" "--issue-workflow-stage=$workflow_stage"
done
