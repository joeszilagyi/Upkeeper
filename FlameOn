#!/usr/bin/env bash
set -euo pipefail

# Thin max-cover smoke/burn launcher for one quota-guarded Upkeeper cycle.

ROOT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
UPKEEPER_CMD="${UPKEEPER_CMD:-$ROOT_DIR/Upkeeper}"
source "$ROOT_DIR/lib/upkeeper/launcher_full_burn.bash"
source "$ROOT_DIR/lib/upkeeper/automation_obligations.bash"
upkeeper_launcher_apply_full_burn_defaults
upkeeper_launcher_apply_automation_identity "FlameOn" "bug-finding" "max-cover-bug-report"

FLAMEON_VERBOSITY="${FLAMEON_VERBOSITY:-basic}"
FLAMEON_MODEL_OVERRIDE="${FLAMEON_MODEL_OVERRIDE:-5.5_xhigh}"
FLAMEON_REQUESTED_MODEL=""
FLAMEON_REQUESTED_REASONING_EFFORT=""
FLAMEON_BACKUP_QUEUE="0"

usage() {
  cat <<EOF
Usage: ${0##*/} [--silent|--basic|--debug1] [--model-override=SPEC] [--model MODEL] [--reasoning-effort EFFORT] [-backup_queue|--backup-queue] [--help]

Run one quota-respecting Upkeeper max-cover cycle:
  - reconcile open Upkeeper automation obligations before normal burn selection
  - gpt-5.5 xhigh via Upkeeper's model override
  - all P1-P23 passes plus P24-P29 review modules
  - Lattice max-cover target ranking
  - bug-report-only investigation and issue filing instead of source fixing
  - fail-closed launcher full burn: Lattice required, encrypted pre-contact
    backup required, and workspace-write containment pinned before launch

Flags:
  --silent        Set CODEX_TERMINAL_VERBOSITY=silent
  --basic         Set CODEX_TERMINAL_VERBOSITY=basic (default)
  --debug1        Set CODEX_TERMINAL_VERBOSITY=debug1
  --model-override=SPEC
                  Upkeeper model override, such as 5.5_xhigh or
                  5.3-codex-spark_xhigh
  --model MODEL   Model shortcut converted to a model override
  --reasoning-effort EFFORT
                  Reasoning effort for --model (default: xhigh)
  -backup_queue   Use the backup local failure queue for this cycle
  --backup-queue  Same as -backup_queue
  --help          Show this help

Environment:
  UPKEEPER_CMD             Upkeeper command path (default: ./Upkeeper)
  FLAMEON_MODEL_OVERRIDE   Upkeeper model override (default: 5.5_xhigh)
  FLAMEON_VERBOSITY        Default verbosity when no flag is given
  FLAMEON_DRY_RUN          Set to 1 to print the resolved command
  UPKEEPER_PRECONTACT_BACKUP_AGE_RECIPIENT
                           Required for live encrypted backup full burn
EOF
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --help|-h)
      usage
      exit 0
      ;;
    --silent)
      FLAMEON_VERBOSITY="silent"
      shift
      ;;
    --basic)
      FLAMEON_VERBOSITY="basic"
      shift
      ;;
    --debug1)
      FLAMEON_VERBOSITY="debug1"
      shift
      ;;
    --model-override=*)
      FLAMEON_MODEL_OVERRIDE="${1#--model-override=}"
      [[ -n "$FLAMEON_MODEL_OVERRIDE" ]] || {
        printf 'FlameOn: --model-override requires a value\n' >&2
        exit 64
      }
      shift
      ;;
    --model-override)
      [[ $# -ge 2 && -n "${2:-}" ]] || {
        printf 'FlameOn: --model-override requires a value\n' >&2
        exit 64
      }
      FLAMEON_MODEL_OVERRIDE="$2"
      shift 2
      ;;
    --model=*)
      FLAMEON_REQUESTED_MODEL="${1#--model=}"
      [[ -n "$FLAMEON_REQUESTED_MODEL" ]] || {
        printf 'FlameOn: --model requires a value\n' >&2
        exit 64
      }
      shift
      ;;
    --model)
      [[ $# -ge 2 && -n "${2:-}" ]] || {
        printf 'FlameOn: --model requires a value\n' >&2
        exit 64
      }
      FLAMEON_REQUESTED_MODEL="$2"
      shift 2
      ;;
    --reasoning-effort=*)
      FLAMEON_REQUESTED_REASONING_EFFORT="${1#--reasoning-effort=}"
      [[ -n "$FLAMEON_REQUESTED_REASONING_EFFORT" ]] || {
        printf 'FlameOn: --reasoning-effort requires a value\n' >&2
        exit 64
      }
      shift
      ;;
    --reasoning-effort)
      [[ $# -ge 2 && -n "${2:-}" ]] || {
        printf 'FlameOn: --reasoning-effort requires a value\n' >&2
        exit 64
      }
      FLAMEON_REQUESTED_REASONING_EFFORT="$2"
      shift 2
      ;;
    -backup_queue|--backup-queue)
      FLAMEON_BACKUP_QUEUE="1"
      shift
      ;;
    *)
      printf 'FlameOn: unknown argument: %s\n' "$1" >&2
      usage >&2
      exit 64
      ;;
  esac
done

case "$FLAMEON_VERBOSITY" in
  silent|basic|debug1)
    ;;
  *)
    printf 'FlameOn: unsupported verbosity: %s\n' "$FLAMEON_VERBOSITY" >&2
    exit 64
    ;;
esac

if [[ -n "$FLAMEON_REQUESTED_MODEL" ]]; then
  if ! FLAMEON_MODEL_OVERRIDE="$(upkeeper_launcher_model_override_from_model_effort "$FLAMEON_REQUESTED_MODEL" "${FLAMEON_REQUESTED_REASONING_EFFORT:-xhigh}")"; then
    printf 'FlameOn: unsupported model/effort pair: %s %s (supported: gpt-5.5 xhigh, gpt-5.3-codex-spark xhigh)\n' \
      "$FLAMEON_REQUESTED_MODEL" "${FLAMEON_REQUESTED_REASONING_EFFORT:-xhigh}" >&2
    exit 64
  fi
elif [[ -n "$FLAMEON_REQUESTED_REASONING_EFFORT" ]]; then
  printf 'FlameOn: --reasoning-effort requires --model\n' >&2
  exit 64
fi

if [[ ! -x "$UPKEEPER_CMD" ]]; then
  printf 'FlameOn: Upkeeper command is not executable: %s\n' "$UPKEEPER_CMD" >&2
  exit 127
fi

obligation_json="$(automation_select_open_obligation_json)"
obligation_status="$(automation_json_field "$obligation_json" status)"
if [[ "$obligation_status" == "ok" ]]; then
  obligation_id="$(automation_json_field "$obligation_json" id)"
  obligation_path="$(automation_json_field "$obligation_json" path)"
  obligation_target="$(automation_json_field "$obligation_json" target_file)"
  obligation_kind="$(automation_json_field "$obligation_json" kind)"
  obligation_summary="$(automation_json_field "$obligation_json" summary)"
  obligation_prompt_file="$(automation_prepare_obligation_prompt_file "$obligation_json")" || {
    printf 'FlameOn: failed to prepare automation obligation prompt\n' >&2
    exit 3
  }
  UPKEEPER_AUTOMATION_WORKFLOW="obligation-repair"
  UPKEEPER_AUTOMATION_OBLIGATION_ID="$obligation_id"
  UPKEEPER_AUTOMATION_OBLIGATION_PATH="$obligation_path"
  export UPKEEPER_AUTOMATION_WORKFLOW
  export UPKEEPER_AUTOMATION_OBLIGATION_ID
  export UPKEEPER_AUTOMATION_OBLIGATION_PATH

  args=(
    "--model-override=$FLAMEON_MODEL_OVERRIDE"
    "--prompt-pass=all"
    "--review-modules=p24,p25,p26,p27,p28,p29"
    "--target-file=$obligation_target"
    "--prompt-file"
    "$obligation_prompt_file"
  )

  if [[ "$FLAMEON_BACKUP_QUEUE" == "1" ]]; then
    args+=("--backup-queue")
  fi

  printf 'FlameOn: selected automation obligation %s for repair\n' "$obligation_id" >&2
  printf 'FlameOn: obligation kind=%s target=%s summary=%s\n' "$obligation_kind" "$obligation_target" "$obligation_summary" >&2

  if [[ "${FLAMEON_DRY_RUN:-0}" == "1" ]]; then
    upkeeper_launcher_print_full_burn_env_prefix
    printf 'CODEX_TERMINAL_VERBOSITY=%q ' "$FLAMEON_VERBOSITY"
    printf '%q' "$UPKEEPER_CMD"
    printf ' %q' "${args[@]}"
    printf '\n'
    exit 0
  fi

  upkeeper_launcher_report_full_burn "FlameOn"
  CODEX_TERMINAL_VERBOSITY="$FLAMEON_VERBOSITY" exec "$UPKEEPER_CMD" "${args[@]}"
fi

args=(
  "--model-override=$FLAMEON_MODEL_OVERRIDE"
  "--max-cover"
  "--bug-report-only"
)

if [[ "$FLAMEON_BACKUP_QUEUE" == "1" ]]; then
  args+=("--backup-queue")
fi

if [[ "${FLAMEON_DRY_RUN:-0}" == "1" ]]; then
  upkeeper_launcher_print_full_burn_env_prefix
  printf 'CODEX_TERMINAL_VERBOSITY=%q ' "$FLAMEON_VERBOSITY"
  printf '%q' "$UPKEEPER_CMD"
  printf ' %q' "${args[@]}"
  printf '\n'
  exit 0
fi

upkeeper_launcher_report_full_burn "FlameOn"
CODEX_TERMINAL_VERBOSITY="$FLAMEON_VERBOSITY" exec "$UPKEEPER_CMD" "${args[@]}"
