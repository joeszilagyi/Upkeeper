# Postmortem summaries are copied into the root loop log so the terminal scroll
# carries the key facts even if the operator never opens the full report.
emit_postmortem_summary() {
  local report_path="$1"
  local trigger="$2"
  local sequence_status="$3"

  local summary_block
  local marker_path marker_block
  if [[ -s "$report_path" ]]; then
    summary_block="$(
      awk '
        /^## Incident Summary$/ { section="Incident Summary"; count=0; next }
        /^## Action Plan$/ { section="Action Plan"; count=0; next }
        /^## Hardening Outcome$/ { section="Hardening Outcome"; count=0; next }
        /^## / { section=""; next }
        section != "" && count < 6 && NF {
          if (!(section in seen)) {
            print section ":"
            seen[section]=1
          }
          print $0
          count++
        }
      ' "$report_path"
    )"
  else
    summary_block="Report file missing or empty."
  fi

  marker_path="$CODEX_POSTMORTEM_DIR/$CYCLE_ID/primary-quota-blocked-until.txt"
  if [[ -s "$marker_path" ]]; then
    marker_block="$(
      printf 'Cooldown Marker:\n'
      printf 'cooldown_marker_path: %s\n' "$marker_path"
      printf 'blocked_bucket: %s\n' "$(marker_field "$marker_path" "blocked_bucket")"
      printf 'blocked_until: %s\n' "$(marker_field "$marker_path" "blocked_until")"
      printf 'recommended_operator_action: %s\n' "$(marker_field "$marker_path" "recommended_operator_action")"
    )"
  else
    marker_block=""
  fi

  {
    printf 'POSTMORTEM_SUMMARY_BEGIN cycle=%s trigger=%s status=%s report=%s\n' "$CYCLE_ID" "$trigger" "$sequence_status" "$report_path"
    if [[ -n "$summary_block" ]]; then
      printf '%s\n' "$summary_block" | sed 's/^/  /'
    fi
    if [[ -n "$marker_block" ]]; then
      printf '%s\n' "$marker_block" | sed 's/^/  /'
    fi
    printf 'POSTMORTEM_SUMMARY_END\n'
  } | tee -a "$LOG_FILE"
}

run_postmortem_sequence() {
  local trigger="$1"
  local detail_text="$2"
  local child_exit="$3"

  POSTMORTEM_REPORT_PATH=""
  POSTMORTEM_CONTEXT_PATH=""
  POSTMORTEM_INCIDENT_LOG_PATH=""
  POSTMORTEM_BUG_RECORD_PATH=""
  POSTMORTEM_SEQUENCE_STATUS="not_run"

  local pm_root report_path context_path incident_log_path bug_record_path primary_last_message_copy
  local report_prompt_file report_last_message hardening_prompt_file hardening_last_message
  local report_exit report_marker hardening_exit hardening_marker
  local incident_classification

  pm_root="$CODEX_POSTMORTEM_DIR/$CYCLE_ID"
  report_path="$pm_root/postmortem.md"
  context_path="$pm_root/incident-context.txt"
  incident_log_path="$pm_root/incident-log.txt"
  bug_record_path="$pm_root/bug-record.md"
  primary_last_message_copy="$pm_root/primary-last-message.txt"

  mkdir -p "$pm_root"
  POSTMORTEM_INCIDENT_LOG_PATH="$incident_log_path"
  refresh_postmortem_incident_log "$incident_log_path"
  if [[ -n "${last_message_file:-}" && -f "${last_message_file:-}" ]]; then
    cp "$last_message_file" "$primary_last_message_copy"
  else
    : >"$primary_last_message_copy"
  fi
  write_postmortem_context "$context_path" "$trigger" "$detail_text" "$child_exit" "$incident_log_path" "$primary_last_message_copy"
  incident_classification="$(awk -F': ' '/^incident_classification: / { print $2; exit }' "$context_path" || true)"
  log_line "INFO" "postmortem.classification trigger=$trigger classification=${incident_classification:-unknown} child_exit=$child_exit"

  POSTMORTEM_REPORT_PATH="$report_path"
  POSTMORTEM_CONTEXT_PATH="$context_path"
  POSTMORTEM_BUG_RECORD_PATH="$bug_record_path"
  write_postmortem_bug_record "$bug_record_path" "$trigger" "$detail_text" "$child_exit" "$POSTMORTEM_SEQUENCE_STATUS" "$report_path" "$context_path" "$incident_log_path"
  log_line "INFO" "postmortem.bug_record path=$bug_record_path trigger=$trigger status=$POSTMORTEM_SEQUENCE_STATUS"

  if [[ "$UPKEEPER_DRY_RUN" == "1" ]]; then
    cat >"$report_path" <<EOF
# Upkeeper Postmortem
## Incident Summary
Dry-run stub summary for trigger $trigger.
## Observed Signals
- Dry run skipped live post-mortem Codex exec.
## Root Cause Hypotheses
- Dry run path only.
## Action Plan
- Relaunch the loop with the updated wrapper.
## Hardening Targets
- Verify fallback and post-mortem branches on the next real incident.
## Relaunch Checklist
- Inspect the real report after a live fallback incident.
## Hardening Outcome
- Dry run only; no live hardening change was executed.
EOF
    POSTMORTEM_SEQUENCE_STATUS="dry_run_stub"
    write_postmortem_bug_record "$bug_record_path" "$trigger" "$detail_text" "$child_exit" "$POSTMORTEM_SEQUENCE_STATUS" "$report_path" "$context_path" "$incident_log_path"
    emit_postmortem_summary "$report_path" "$trigger" "$POSTMORTEM_SEQUENCE_STATUS"
    return 7
  fi

  report_prompt_file="$(mktemp)"
  report_last_message="$(mktemp)"
  hardening_prompt_file="$(mktemp)"
  hardening_last_message="$(mktemp)"

  compile_postmortem_report_prompt "$report_prompt_file" "$context_path" "$report_path"
  run_aux_codex_exec "postmortem.report" "$CODEX_POSTMORTEM_MODEL" "$CODEX_POSTMORTEM_REASONING_EFFORT" "$CODEX_POSTMORTEM_MODE" "$report_prompt_file" "$report_last_message"
  report_exit=$?
  report_marker="$(parse_postmortem_marker "$report_last_message")"
  log_line "INFO" "postmortem.report.finish exit_code=$report_exit marker=${report_marker:-missing} report_path=$report_path report_exists=$([[ -e "$report_path" ]] && printf 1 || printf 0) report_nonempty=$([[ -s "$report_path" ]] && printf 1 || printf 0)"

  if [[ "$report_exit" -eq 86 ]]; then
    POSTMORTEM_SEQUENCE_STATUS="report_quota_skipped"
    write_quota_skipped_postmortem_report "$report_path" "$trigger" "$detail_text" "$child_exit" "postmortem.report" "$CODEX_POSTMORTEM_MODEL"
    log_line "WARN" "postmortem.report skipped reason=quota_guardrail exit_code=$report_exit marker=${report_marker:-missing} report_path=$report_path"
    write_postmortem_bug_record "$bug_record_path" "$trigger" "$detail_text" "$child_exit" "$POSTMORTEM_SEQUENCE_STATUS" "$report_path" "$context_path" "$incident_log_path"
    emit_postmortem_summary "$report_path" "$trigger" "$POSTMORTEM_SEQUENCE_STATUS"
    rm -f "$report_prompt_file" "$report_last_message" "$hardening_prompt_file" "$hardening_last_message"
    return 7
  fi

  if [[ "$report_exit" -eq 87 ]]; then
    local report_environment_detail report_environment_reason
    report_environment_detail="$(awk '/^detail: / { sub(/^detail: /, ""); print; exit }' "$report_last_message" || true)"
    if [[ -z "$report_environment_detail" ]]; then
      report_environment_detail="unknown"
    fi
    report_environment_reason="$(awk '/^reason: / { sub(/^reason: /, ""); print; exit }' "$report_last_message" || true)"
    if [[ -z "$report_environment_reason" ]]; then
      report_environment_reason="local Codex runtime is not writable"
    fi
    POSTMORTEM_SEQUENCE_STATUS="report_environment_skipped"
    write_environment_skipped_postmortem_report "$report_path" "$trigger" "$detail_text" "$child_exit" "postmortem.report" "$CODEX_POSTMORTEM_MODEL" "$report_environment_detail"
    log_line "WARN" "postmortem.report skipped reason=local_codex_runtime_unwritable environment_reason=$(shell_quote "$report_environment_reason") exit_code=$report_exit marker=${report_marker:-missing} report_path=$report_path"
    write_postmortem_bug_record "$bug_record_path" "$trigger" "$detail_text" "$child_exit" "$POSTMORTEM_SEQUENCE_STATUS" "$report_path" "$context_path" "$incident_log_path"
    emit_postmortem_summary "$report_path" "$trigger" "$POSTMORTEM_SEQUENCE_STATUS"
    rm -f "$report_prompt_file" "$report_last_message" "$hardening_prompt_file" "$hardening_last_message"
    return 7
  fi

  if [[ "$report_exit" -ne 0 || "$report_marker" == "BLOCKED" || ! -s "$report_path" ]]; then
    POSTMORTEM_SEQUENCE_STATUS="report_failed"
    log_line "ERROR" "postmortem.report failed exit_code=$report_exit marker=${report_marker:-missing} report_path=$report_path"
    write_postmortem_bug_record "$bug_record_path" "$trigger" "$detail_text" "$child_exit" "$POSTMORTEM_SEQUENCE_STATUS" "$report_path" "$context_path" "$incident_log_path"
    emit_postmortem_summary "$report_path" "$trigger" "$POSTMORTEM_SEQUENCE_STATUS"
    rm -f "$report_prompt_file" "$report_last_message" "$hardening_prompt_file" "$hardening_last_message"
    return 8
  fi

  compile_postmortem_hardening_prompt "$hardening_prompt_file" "$context_path" "$report_path"
  run_aux_codex_exec "postmortem.hardening" "$CODEX_POSTMORTEM_MODEL" "$CODEX_POSTMORTEM_REASONING_EFFORT" "$CODEX_POSTMORTEM_MODE" "$hardening_prompt_file" "$hardening_last_message"
  hardening_exit=$?
  hardening_marker="$(parse_postmortem_marker "$hardening_last_message")"

  if [[ "$hardening_exit" -eq 86 ]]; then
    POSTMORTEM_SEQUENCE_STATUS="hardening_quota_skipped"
    cat >>"$report_path" <<EOF

## Hardening Outcome
- The scripted hardening Codex pass was skipped before launch because \`$CODEX_POSTMORTEM_MODEL\` did not pass the auxiliary quota preflight.
- The report was preserved and the wrapper stopped for manual relaunch instead of spending more recovery quota.
EOF
    log_line "WARN" "postmortem.hardening skipped reason=quota_guardrail exit_code=$hardening_exit marker=${hardening_marker:-missing} report_path=$report_path"
    write_postmortem_bug_record "$bug_record_path" "$trigger" "$detail_text" "$child_exit" "$POSTMORTEM_SEQUENCE_STATUS" "$report_path" "$context_path" "$incident_log_path"
    emit_postmortem_summary "$report_path" "$trigger" "$POSTMORTEM_SEQUENCE_STATUS"
    rm -f "$report_prompt_file" "$report_last_message" "$hardening_prompt_file" "$hardening_last_message"
    return 7
  fi

  if [[ "$hardening_exit" -eq 87 ]]; then
    POSTMORTEM_SEQUENCE_STATUS="hardening_environment_skipped"
    cat >>"$report_path" <<EOF

## Hardening Outcome
- The scripted hardening Codex pass was skipped before launch because the local Codex runtime was not writable.
- The report was preserved and the wrapper stopped for manual relaunch instead of recursively launching Codex in the same broken environment.
EOF
    log_line "WARN" "postmortem.hardening skipped reason=local_codex_runtime_unwritable exit_code=$hardening_exit marker=${hardening_marker:-missing} report_path=$report_path"
    write_postmortem_bug_record "$bug_record_path" "$trigger" "$detail_text" "$child_exit" "$POSTMORTEM_SEQUENCE_STATUS" "$report_path" "$context_path" "$incident_log_path"
    emit_postmortem_summary "$report_path" "$trigger" "$POSTMORTEM_SEQUENCE_STATUS"
    rm -f "$report_prompt_file" "$report_last_message" "$hardening_prompt_file" "$hardening_last_message"
    return 7
  fi

  if [[ "$hardening_exit" -ne 0 || "$hardening_marker" == "BLOCKED" ]]; then
    POSTMORTEM_SEQUENCE_STATUS="hardening_failed"
    log_line "ERROR" "postmortem.hardening failed exit_code=$hardening_exit marker=${hardening_marker:-missing} report_path=$report_path"
    write_postmortem_bug_record "$bug_record_path" "$trigger" "$detail_text" "$child_exit" "$POSTMORTEM_SEQUENCE_STATUS" "$report_path" "$context_path" "$incident_log_path"
    emit_postmortem_summary "$report_path" "$trigger" "$POSTMORTEM_SEQUENCE_STATUS"
    rm -f "$report_prompt_file" "$report_last_message" "$hardening_prompt_file" "$hardening_last_message"
    return 8
  fi

  POSTMORTEM_SEQUENCE_STATUS="complete"
  write_postmortem_bug_record "$bug_record_path" "$trigger" "$detail_text" "$child_exit" "$POSTMORTEM_SEQUENCE_STATUS" "$report_path" "$context_path" "$incident_log_path"
  emit_postmortem_summary "$report_path" "$trigger" "$POSTMORTEM_SEQUENCE_STATUS"
  rm -f "$report_prompt_file" "$report_last_message" "$hardening_prompt_file" "$hardening_last_message"
  return 7
}

# Fallback orchestration.
#
# A fallback child is still one cycle, just with stronger defaults and extra
# context. The parent owns the postmortem sequence because incident evidence is
# about the failed handoff as a whole, not only the child run.
run_fallback_cycle() {
  local trigger="$1"
  shift
  local detail_text="${*:-none}"
  local child_exit=0
  local source_model="$CODEX_MODEL"
  local bwrap_tmp_detail bwrap_tmp_detail_q

  if [[ "$UPKEEPER_DRY_RUN" == "1" ]]; then
    bwrap_tmp_detail="ok"
  else
    bwrap_tmp_detail="$(codex_bwrap_tmp_write_check | compact_process_args || true)"
  fi
  if [[ "$bwrap_tmp_detail" != "ok" ]]; then
    bwrap_tmp_detail_q="$(shell_quote "$bwrap_tmp_detail")"
    log_line "WARN" "fallback.skip trigger=$trigger reason=codex_bwrap_tmp_unwritable registry_root=$(shell_quote "$CODEX_BWRAP_TMP_ROOT") detail=$bwrap_tmp_detail_q"
    child_exit=3
  elif fallback_would_rediscover_dirty_block "$trigger"; then
    log_line "WARN" "fallback.skip trigger=$trigger reason=dirty_worktree_predicted_block dirty_paths=$DIRTY_PATH_COUNT tracked_modified_paths=$TRACKED_MODIFIED_PATH_COUNT untracked_paths=$UNTRACKED_PATH_COUNT mode=normal_backend_prompt"
    child_exit=2
  elif [[ "$CODEX_FALLBACK_SCREEN_ENABLED" == "1" ]]; then
    if ! launch_screen_fallback_loop "$trigger" "$detail_text"; then
      log_line "ERROR" "fallback.screen.start failed trigger=$trigger"
      child_exit=8
    else
      wait_for_screen_fallback_loop "$trigger" "$FALLBACK_SCREEN_SESSION_NAME" "$CODEX_POSTMORTEM_DIR/$CYCLE_ID/screen/final-exit-code.txt" "$CODEX_POSTMORTEM_DIR/$CYCLE_ID/screen/done.txt"
      child_exit="${FALLBACK_SCREEN_EXIT_CODE:-8}"
    fi
  else
    log_line "INFO" "fallback.start execution_origin=primary trigger=$trigger mode=direct from_model=$source_model to_model=$CODEX_FALLBACK_MODEL detail=\"$detail_text\""
    if [[ "$UPKEEPER_DRY_RUN" == "1" ]]; then
      log_line "INFO" "dry-run active; skipping direct fallback child exec trigger=$trigger target_model=$CODEX_FALLBACK_MODEL"
      child_exit=0
    else
      local -a child_args=()
      if [[ -n "$PROMPT_FILE" ]]; then
        child_args+=(--prompt-file "$PROMPT_FILE")
      elif [[ -n "$INLINE_PROMPT" ]]; then
        child_args+=(--prompt "$INLINE_PROMPT")
      fi
      set +e
      CODEX_MODEL="$CODEX_FALLBACK_MODEL" \
      CODEX_REASONING_EFFORT="$CODEX_FALLBACK_REASONING_EFFORT" \
      CODEX_MODE="$CODEX_FALLBACK_MODE" \
      CODEX_FALLBACK_ENABLED=0 \
      CODEX_FALLBACK_CHAIN_ACTIVE=1 \
      CODEX_ATTEMPT_ROLE=fallback \
      CODEX_PRIMARY_MODEL_CONTEXT="$source_model" \
      CODEX_FALLBACK_TRIGGER="$trigger" \
      CODEX_PARENT_CYCLE_ID="$CYCLE_ID" \
      CODEX_POSTMORTEM_ENABLED=0 \
      CODEX_DISABLE_PARENT_STOP=1 \
      CODEX_GUARDRAIL_STOP_EXIT_CODE=9 \
      CODEX_EXECUTION_ORIGIN=screen \
      "$SELF_INVOKE_PATH" "${child_args[@]}"
      child_exit=$?
      set -e
    fi
  fi

  local final_exit="$child_exit"
  if [[ "$CODEX_POSTMORTEM_ENABLED" == "1" ]]; then
    set +e
    run_postmortem_sequence "$trigger" "$detail_text" "$child_exit"
    final_exit=$?
    set -e
  fi

  log_line "INFO" "fallback.finish trigger=$trigger child_exit=$child_exit final_exit=$final_exit child_model=$CODEX_FALLBACK_MODEL child_effort=$CODEX_FALLBACK_REASONING_EFFORT parent_cycle_id=$CYCLE_ID execution_origin=$([[ "$CODEX_FALLBACK_SCREEN_ENABLED" == "1" ]] && printf screen || printf primary) postmortem_status=$POSTMORTEM_SEQUENCE_STATUS report_path=${POSTMORTEM_REPORT_PATH:-none} screen_session=${FALLBACK_SCREEN_SESSION_NAME:-none}"
  refresh_postmortem_incident_log "${POSTMORTEM_INCIDENT_LOG_PATH:-}"
  return "$final_exit"
}

# Codex final response markers are the contract between the model and wrapper.
# Session-end parsing is only a fallback diagnostic for cases where the marker is
# missing and the operator needs to know whether the turn aborted or completed
# without an agent message.
parse_status_marker() {
  local last_message_file="$1"
  local analysis
  analysis="$(while_marker_analysis_json "$last_message_file")"
  json_field "$analysis" '.accepted_marker'
}

resolved_status_marker_from_analysis() {
  local analysis="$1"
  local codex_exit="$2"
  local task_complete_last_agent_message="$3"
  local accepted candidate reason

  accepted="$(json_field "$analysis" '.accepted_marker')"
  if [[ -n "$accepted" ]]; then
    printf '%s' "$accepted"
    return 0
  fi

  candidate="$(json_field "$analysis" '.candidate_marker')"
  reason="$(json_field "$analysis" '.candidate_rejection_reason')"
  if [[ -n "$candidate" && "$reason" != "decorated_marker" && "$codex_exit" == "0" && "$task_complete_last_agent_message" == "present" ]]; then
    printf '%s' "$candidate"
  fi
}

parse_session_end_state() {
  local session_file="$1"
  [[ -n "$session_file" && -f "$session_file" ]] || {
    printf 'none'
    return 0
  }

  python3 - "$session_file" <<'PY'
import json
import sys

path = sys.argv[1]
state = "none"

try:
    with open(path, "r", encoding="utf-8", errors="ignore") as handle:
        for raw_line in handle:
            try:
                item = json.loads(raw_line)
            except json.JSONDecodeError:
                continue
            if item.get("type") != "event_msg":
                continue
            payload = item.get("payload") or {}
            if payload.get("type") == "turn_aborted":
                reason = payload.get("reason") or "unknown"
                state = f"turn_aborted:{reason}"
            elif (
                payload.get("type") == "task_complete"
                and "last_agent_message" in payload
                and payload.get("last_agent_message") is None
            ):
                if state == "none":
                    state = "no_agent_message"
except OSError:
    pass

print(state)
PY
}

session_diagnostics_json() {
  local session_file="$1"
  [[ -n "$session_file" && -f "$session_file" ]] || {
    printf '{"agent_message_count":0,"tool_call_count":0,"tool_result_count":0,"task_complete_last_agent_message":"missing","last_rate_limit_reached_type":"unknown","last_rate_limit_limit_id":"unknown","last_rate_limit_limit_name":"unknown","last_rate_limit_plan_type":"unknown","last_rate_limit_primary_used_percent":"unknown","last_rate_limit_secondary_used_percent":"unknown"}'
    return 0
  }

  python3 - "$session_file" <<'PY'
import json
import sys

path = sys.argv[1]
summary = {
    "agent_message_count": 0,
    "tool_call_count": 0,
    "tool_result_count": 0,
    "task_complete_last_agent_message": "missing",
    "last_rate_limit_reached_type": "unknown",
    "last_rate_limit_limit_id": "unknown",
    "last_rate_limit_limit_name": "unknown",
    "last_rate_limit_plan_type": "unknown",
    "last_rate_limit_primary_used_percent": "unknown",
    "last_rate_limit_secondary_used_percent": "unknown",
}

try:
    with open(path, "r", encoding="utf-8", errors="ignore") as handle:
        for raw_line in handle:
            try:
                item = json.loads(raw_line)
            except json.JSONDecodeError:
                continue

            payload = item.get("payload") or {}
            payload_type = payload.get("type")

            if item.get("type") == "response_item":
                if payload_type == "message" and payload.get("role") == "assistant":
                    summary["agent_message_count"] += 1
                elif payload_type == "function_call":
                    summary["tool_call_count"] += 1
                elif payload_type == "function_call_output":
                    summary["tool_result_count"] += 1
                continue

            if item.get("type") != "event_msg":
                continue

            if payload_type == "task_complete" and "last_agent_message" in payload:
                last_agent_message = payload.get("last_agent_message")
                if last_agent_message is None:
                    summary["task_complete_last_agent_message"] = "null"
                elif isinstance(last_agent_message, str) and last_agent_message.strip():
                    summary["task_complete_last_agent_message"] = "present"
                else:
                    summary["task_complete_last_agent_message"] = "blank"
            elif payload_type == "token_count":
                rate_limits = payload.get("rate_limits") or {}
                primary = rate_limits.get("primary") or {}
                secondary = rate_limits.get("secondary") or {}
                summary["last_rate_limit_reached_type"] = rate_limits.get("rate_limit_reached_type")
                if summary["last_rate_limit_reached_type"] is None:
                    summary["last_rate_limit_reached_type"] = "null"
                summary["last_rate_limit_limit_id"] = rate_limits.get("limit_id") or "unknown"
                summary["last_rate_limit_limit_name"] = rate_limits.get("limit_name") or "unknown"
                summary["last_rate_limit_plan_type"] = rate_limits.get("plan_type")
                if summary["last_rate_limit_plan_type"] is None:
                    summary["last_rate_limit_plan_type"] = "null"
                summary["last_rate_limit_primary_used_percent"] = primary.get("used_percent", "unknown")
                summary["last_rate_limit_secondary_used_percent"] = secondary.get("used_percent", "unknown")
except OSError:
    pass

print(json.dumps(summary, sort_keys=True))
PY
}

# Main cycle.
#
# Order matters:
# 1. establish local evidence paths and current worktree state,
# 2. read quota state before spending anything,
# 3. run exactly one Codex task when guardrails allow it,
# 4. classify the model's final marker,
# 5. hand off to bounded fallback/postmortem only when that reduces risk.
main() {
  parse_args "$@"
  ensure_log_parent
  require_commands
  normalize_guardrail_thresholds
  ensure_operator_guide
  resolve_prompt_file
  rotate_wrapper_log_if_needed
  refresh_worktree_counts

  local direct_parent_pid direct_parent_comm direct_parent_args
  if details="$(direct_parent_details)"; then
    IFS=$'\t' read -r direct_parent_pid direct_parent_comm direct_parent_args <<<"$details"
  else
    direct_parent_pid="unknown"
    direct_parent_comm="unknown"
    direct_parent_args="unknown"
  fi

  local loop_parent_pid loop_parent_comm loop_parent_args loop_parent_override
  if details="$(parent_shell_details)"; then
    IFS=$'\t' read -r loop_parent_pid loop_parent_comm loop_parent_args loop_parent_override <<<"$details"
  else
    loop_parent_pid="unknown"
    loop_parent_comm="unknown"
    loop_parent_args="unknown"
    loop_parent_override="0"
  fi

  log_line "INFO" "cycle.start execution_origin=$CODEX_EXECUTION_ORIGIN script=$SELF_INVOKE_PATH implementation=$SELF_PATH cwd=$ROOT_DIR pid=$$ ppid=$direct_parent_pid parent_comm=$direct_parent_comm loop_parent_pid=$loop_parent_pid loop_parent_comm=$loop_parent_comm loop_parent_override=$loop_parent_override model=$CODEX_MODEL effort=$CODEX_REASONING_EFFORT mode=$CODEX_MODE_STRING model_override=${CODEX_MODEL_OVERRIDE_SPEC:-none} model_override_applied=$CODEX_MODEL_OVERRIDE_APPLIED attempt_role=$CODEX_ATTEMPT_ROLE fallback_chain_active=$CODEX_FALLBACK_CHAIN_ACTIVE primary_model_context=${CODEX_PRIMARY_MODEL_CONTEXT:-none} fallback_trigger=${CODEX_FALLBACK_TRIGGER:-none} screen_fallback_child_id=${CODEX_SCREEN_FALLBACK_CHILD_ID:-none} code_home=$CODEX_HOME_DIR dry_run=$UPKEEPER_DRY_RUN continue_on_no_backend_task=$CODEX_CONTINUE_ON_NO_BACKEND_TASK dirty_paths=$DIRTY_PATH_COUNT tracked_modified_paths=$TRACKED_MODIFIED_PATH_COUNT untracked_paths=$UNTRACKED_PATH_COUNT"

  enforce_primary_quota_block_marker

  local quota_json
  quota_json="$(quota_state_json)"
  if [[ "$(json_field "$quota_json" '.error // empty')" == "no_rate_limit_snapshot_found" ]]; then
    die "no Codex rate-limit snapshot found under $CODEX_HOME_DIR/sessions; run a normal Codex session first or check CODEX_HOME"
  fi
  if [[ "$(json_field "$quota_json" '.error // empty')" == "interrupted" ]]; then
    log_line "WARN" "quota snapshot scan interrupted by operator before cycle start completed"
    finish_cycle 130 QUOTA_SCAN_INTERRUPTED WARN "phase=before_start"
  fi

  local before_ts before_source before_model_hint before_selection before_matching_snapshot_count before_snapshot_is_current
  local before_snapshot_age_seconds before_primary_reset_age_seconds before_secondary_reset_age_seconds before_snapshot_stale_after_reset
  local before_primary_reset_expired before_secondary_reset_expired before_primary_bucket_current before_secondary_bucket_current
  local primary_used primary_window primary_reset
  local secondary_used secondary_window secondary_reset
  local plan_type limit_id limit_name
  local expected_quota_identity quota_identity_status quota_identity_guardrail_decision="allow"
  local projected_primary_delta projected_secondary_delta projected_basis
  local primary_left secondary_left
  local five_hour_threshold
  local primary_projected_used secondary_projected_used
  local primary_projected_left secondary_projected_left
  local primary_guardrail_decision="defer" secondary_guardrail_decision="defer"

  before_ts="$(json_field "$quota_json" '.snapshot.event_timestamp // "unknown"')"
  before_source="$(json_field "$quota_json" '.snapshot.source_path // "unknown"')"
  before_model_hint="$(json_field "$quota_json" '.snapshot.model_hint // "unknown"')"
  before_selection="$(json_field "$quota_json" '.snapshot_selection // "unknown"')"
  before_snapshot_is_current="$(json_field "$quota_json" '.snapshot_is_current // false')"
  before_matching_snapshot_count="$(json_field "$quota_json" '.matching_snapshot_count // 0')"
  before_snapshot_age_seconds="$(json_field "$quota_json" '.snapshot.snapshot_age_seconds // "unknown"')"
  before_primary_reset_age_seconds="$(json_field "$quota_json" '.snapshot.primary_reset_age_seconds // "unknown"')"
  before_secondary_reset_age_seconds="$(json_field "$quota_json" '.snapshot.secondary_reset_age_seconds // "unknown"')"
  before_snapshot_stale_after_reset="$(json_field "$quota_json" '.snapshot.snapshot_stale_after_reset // false')"
  before_primary_reset_expired="$(json_field "$quota_json" '.snapshot.primary_reset_expired // false')"
  before_secondary_reset_expired="$(json_field "$quota_json" '.snapshot.secondary_reset_expired // false')"
  before_primary_bucket_current="$(json_field "$quota_json" '.snapshot.primary_bucket_current // false')"
  before_secondary_bucket_current="$(json_field "$quota_json" '.snapshot.secondary_bucket_current // false')"
  primary_used="$(json_field "$quota_json" '.snapshot.primary_used_percent')"
  primary_window="$(json_field "$quota_json" '.snapshot.primary_window_minutes')"
  primary_reset="$(json_field "$quota_json" '.snapshot.primary_resets_at')"
  secondary_used="$(json_field "$quota_json" '.snapshot.secondary_used_percent')"
  secondary_window="$(json_field "$quota_json" '.snapshot.secondary_window_minutes')"
  secondary_reset="$(json_field "$quota_json" '.snapshot.secondary_resets_at')"
  plan_type="$(json_field "$quota_json" '.snapshot.plan_type // "unknown"')"
  limit_id="$(json_field "$quota_json" '.snapshot.limit_id // "unknown"')"
  limit_name="$(json_field "$quota_json" '.snapshot.limit_name // "unknown"')"
  expected_quota_identity="$(quota_expected_identity_for_model "$CODEX_MODEL")"
  quota_identity_status="$(quota_identity_status_for_model "$CODEX_MODEL" "$limit_id" "$limit_name")"
  projected_primary_delta="$(json_field "$quota_json" '.projection.primary_delta')"
  projected_secondary_delta="$(json_field "$quota_json" '.projection.secondary_delta')"
  projected_basis="$(json_field "$quota_json" '.projection.basis')"
  five_hour_threshold="$(quota_5h_stop_percent_for_model "$CODEX_MODEL")"
  week_threshold="$(quota_week_stop_percent_for_model "$CODEX_MODEL")"
  week_buffer="$(quota_week_stop_buffer_percent_for_model "$CODEX_MODEL")"

  primary_left="$(awk -v used="$primary_used" 'BEGIN { printf "%.1f", 100 - used }')"
  secondary_left="$(awk -v used="$secondary_used" 'BEGIN { printf "%.1f", 100 - used }')"
  primary_projected_used="$(awk -v current="$primary_used" -v delta="$projected_primary_delta" 'BEGIN { printf "%.1f", current + delta }')"
  secondary_projected_used="$(awk -v current="$secondary_used" -v delta="$projected_secondary_delta" 'BEGIN { printf "%.1f", current + delta }')"
  primary_projected_left="$(awk -v used="$primary_projected_used" 'BEGIN { printf "%.1f", 100 - used }')"
  secondary_projected_left="$(awk -v used="$secondary_projected_used" 'BEGIN { printf "%.1f", 100 - used }')"

  if [[ "$before_selection" == "exact_model" ]]; then
    primary_guardrail_decision="$(quota_bucket_decision "$before_primary_bucket_current" "$primary_projected_left" "$five_hour_threshold")"
    secondary_guardrail_decision="$(quota_bucket_decision "$before_secondary_bucket_current" "$secondary_projected_left" "$week_threshold")"
    if ! quota_identity_allows_pre_run "$CODEX_MODEL" "$limit_id" "$limit_name"; then
      quota_identity_guardrail_decision="stop"
    fi
  fi

  log_line "INFO" "quota.current execution_origin=$CODEX_EXECUTION_ORIGIN target_model=$CODEX_MODEL snapshot_selection=$before_selection snapshot_current=$before_snapshot_is_current snapshot_stale_after_reset=$before_snapshot_stale_after_reset primary_reset_expired=$before_primary_reset_expired secondary_reset_expired=$before_secondary_reset_expired primary_bucket_current=$before_primary_bucket_current secondary_bucket_current=$before_secondary_bucket_current matching_snapshot_count=$before_matching_snapshot_count expected_quota_identity=$expected_quota_identity quota_identity_status=$quota_identity_status limit_id=$limit_id limit_name=$(shell_quote "$limit_name") plan_type=$plan_type source=$before_source snapshot_model_hint=$before_model_hint event_timestamp=$before_ts snapshot_age_seconds=$before_snapshot_age_seconds primary_used=${primary_used}% primary_left=${primary_left}% primary_window=${primary_window}m primary_reset=$(format_epoch_local "$primary_reset") primary_reset_age_seconds=$before_primary_reset_age_seconds secondary_used=${secondary_used}% secondary_left=${secondary_left}% secondary_window=${secondary_window}m secondary_reset=$(format_epoch_local "$secondary_reset") secondary_reset_age_seconds=$before_secondary_reset_age_seconds"
  log_line "INFO" "quota.projection execution_origin=$CODEX_EXECUTION_ORIGIN target_model=$CODEX_MODEL basis=$projected_basis expected_quota_identity=$expected_quota_identity quota_identity_status=$quota_identity_status projected_primary_delta_used=${projected_primary_delta}% projected_primary_used=${primary_projected_used}% projected_primary_left=${primary_projected_left}% primary_decision=$primary_guardrail_decision projected_secondary_delta_used=${projected_secondary_delta}% projected_secondary_used=${secondary_projected_used}% projected_secondary_left=${secondary_projected_left}% secondary_decision=$secondary_guardrail_decision left_thresholds=(${five_hour_threshold}%/${week_threshold}%) weekly_base_threshold=${CODEX_WEEK_STOP_PERCENT}% weekly_buffer=${week_buffer}%"

  if [[ "$before_selection" != "exact_model" ]]; then
    log_line "WARN" "quota.current target_model=$CODEX_MODEL using snapshot_selection=$before_selection snapshot_model_hint=$before_model_hint"
  fi

  local should_stop=0
  local stop_reason=""
  if [[ "$before_selection" == "exact_model" ]]; then
    if [[ "$quota_identity_guardrail_decision" == "stop" ]]; then
      should_stop=1
      stop_reason="unsafe Spark quota identity ${quota_identity_status} limit_id=${limit_id} limit_name=${limit_name}; expected ${expected_quota_identity}"
      log_line "WARN" "quota.identity_guardrail target_model=$CODEX_MODEL decision=stop expected_quota_identity=$expected_quota_identity quota_identity_status=$quota_identity_status limit_id=$limit_id limit_name=$(shell_quote "$limit_name") source=$before_source"
    fi
    if [[ "$primary_guardrail_decision" == "stop" ]]; then
      should_stop=1
      if [[ -n "$stop_reason" ]]; then
        stop_reason="$stop_reason; "
      fi
      stop_reason="${stop_reason}projected 5-hour left ${primary_projected_left}% <= ${five_hour_threshold}%"
    fi
    if [[ "$secondary_guardrail_decision" == "stop" ]]; then
      should_stop=1
      if [[ -n "$stop_reason" ]]; then
        stop_reason="$stop_reason; "
      fi
      stop_reason="${stop_reason}projected weekly left ${secondary_projected_left}% <= ${week_threshold}% (base ${CODEX_WEEK_STOP_PERCENT}% + buffer ${week_buffer}%)"
    fi
    if [[ "$primary_guardrail_decision" == "defer" && "$secondary_guardrail_decision" == "defer" ]]; then
      log_line "WARN" "quota.guardrails target_model=$CODEX_MODEL deferred reason=stale_snapshot_after_reset snapshot_current=$before_snapshot_is_current snapshot_stale_after_reset=$before_snapshot_stale_after_reset primary_bucket_current=$before_primary_bucket_current secondary_bucket_current=$before_secondary_bucket_current primary_reset=$(format_epoch_local "$primary_reset") primary_reset_age_seconds=$before_primary_reset_age_seconds secondary_reset=$(format_epoch_local "$secondary_reset") secondary_reset_age_seconds=$before_secondary_reset_age_seconds"
    elif [[ "$primary_guardrail_decision" == "defer" || "$secondary_guardrail_decision" == "defer" ]]; then
      log_line "WARN" "quota.guardrails target_model=$CODEX_MODEL partial_decision primary_decision=$primary_guardrail_decision secondary_decision=$secondary_guardrail_decision primary_bucket_current=$before_primary_bucket_current secondary_bucket_current=$before_secondary_bucket_current primary_reset_expired=$before_primary_reset_expired secondary_reset_expired=$before_secondary_reset_expired"
    fi
  else
    log_line "WARN" "quota.guardrails target_model=$CODEX_MODEL deferred until an exact model snapshot exists"
  fi

  if [[ "$should_stop" -eq 1 ]]; then
    write_primary_quota_blocked_marker "$stop_reason"
    if [[ "$CODEX_ATTEMPT_ROLE" == "primary" && "$CODEX_FALLBACK_ON_PRIMARY_QUOTA" == "1" ]] && fallback_available; then
      local fallback_exit
      run_fallback_cycle "primary_quota_before_run" "$stop_reason"
      fallback_exit=$?
      finish_cycle "$fallback_exit" FALLBACK_CHAIN_EXIT INFO "trigger=primary_quota_before_run final_exit=$fallback_exit target_model=$CODEX_FALLBACK_MODEL postmortem_status=$POSTMORTEM_SEQUENCE_STATUS report_path=${POSTMORTEM_REPORT_PATH:-none}"
    fi
    log_line "WARN" "quota.stop reason=\"$stop_reason\""
    if stop_parent_loop; then
      finish_cycle "$CODEX_GUARDRAIL_STOP_EXIT_CODE" QUOTA_GUARDRAIL_STOP INFO "codex_exec_started=0 execution_origin=$CODEX_EXECUTION_ORIGIN"
    fi
    log_line "ERROR" "cycle.stop failed to confirm parent loop termination"
    finish_cycle 4 QUOTA_GUARDRAIL_STOP_FAILED ERROR "codex_exec_started=0"
  fi

  local compiled_prompt_file
  local last_message_file
  compiled_prompt_file="$(mktemp)"
  last_message_file="$(mktemp)"
  RUN_COMPILED_PROMPT_FILE="$compiled_prompt_file"
  RUN_LAST_MESSAGE_FILE="$last_message_file"
  trap cleanup_run_temp_files EXIT

  compile_prompt "$compiled_prompt_file"

  if [[ "$UPKEEPER_DRY_RUN" == "1" ]]; then
    log_line "INFO" "dry-run active; skipping codex exec"
    finish_cycle 0 DRY_RUN INFO "codex_exec_started=0"
  fi

  ensure_codex_session_store_writable_or_exit "before_run" "0"
  ensure_codex_arg0_tmp_clean_or_exit "before_run" "0"
  ensure_codex_bwrap_tmp_writable_or_exit "before_run" "0"
  log_line "INFO" "run.start execution_origin=$CODEX_EXECUTION_ORIGIN prompt_file=${PROMPT_FILE:-inline/default} compiled_prompt=$compiled_prompt_file"

  set +e
  codex exec \
    "${CODEX_MODE_ARGS[@]}" \
    -C "$ROOT_DIR" \
    -m "$CODEX_MODEL" \
    -c "model_reasoning_effort=\"$CODEX_REASONING_EFFORT\"" \
    -o "$last_message_file" \
    - <"$compiled_prompt_file"
  local codex_exit=$?
  set -e

  log_line "INFO" "run.finish execution_origin=$CODEX_EXECUTION_ORIGIN codex_exit=$codex_exit"

  local after_quota_json=""
  local after_ts="" after_source="" after_selection="" after_model_hint="" after_snapshot_is_current=""
  local after_snapshot_age_seconds="" after_primary_reset_age_seconds="" after_secondary_reset_age_seconds="" after_snapshot_stale_after_reset=""
  local after_primary_reset_expired="" after_secondary_reset_expired="" after_primary_bucket_current="" after_secondary_bucket_current=""
  local after_limit_id="" after_limit_name="" after_plan_type=""
  local after_primary="" after_secondary="" after_primary_reset="" after_secondary_reset=""
  local after_primary_left="" after_secondary_left=""
  local after_primary_guardrail_decision="defer" after_secondary_guardrail_decision="defer"
  after_quota_json="$(quota_state_json)"
  if [[ "$(json_field "$after_quota_json" '.error // empty')" == "interrupted" ]]; then
    log_line "WARN" "quota snapshot scan interrupted by operator after codex exec"
    finish_cycle 130 QUOTA_SCAN_INTERRUPTED WARN "phase=after_run codex_exit=$codex_exit"
  fi
  if [[ "$(json_field "$after_quota_json" '.error // empty')" != "no_rate_limit_snapshot_found" ]]; then
    after_ts="$(json_field "$after_quota_json" '.snapshot.event_timestamp // "unknown"')"
    after_source="$(json_field "$after_quota_json" '.snapshot.source_path // "unknown"')"
    after_selection="$(json_field "$after_quota_json" '.snapshot_selection // "unknown"')"
    after_snapshot_is_current="$(json_field "$after_quota_json" '.snapshot_is_current // false')"
    after_snapshot_age_seconds="$(json_field "$after_quota_json" '.snapshot.snapshot_age_seconds // "unknown"')"
    after_limit_id="$(json_field "$after_quota_json" '.snapshot.limit_id // "unknown"')"
    after_limit_name="$(json_field "$after_quota_json" '.snapshot.limit_name // "unknown"')"
    after_plan_type="$(json_field "$after_quota_json" '.snapshot.plan_type // "unknown"')"
    after_primary_reset_age_seconds="$(json_field "$after_quota_json" '.snapshot.primary_reset_age_seconds // "unknown"')"
    after_secondary_reset_age_seconds="$(json_field "$after_quota_json" '.snapshot.secondary_reset_age_seconds // "unknown"')"
    after_snapshot_stale_after_reset="$(json_field "$after_quota_json" '.snapshot.snapshot_stale_after_reset // false')"
    after_primary_reset_expired="$(json_field "$after_quota_json" '.snapshot.primary_reset_expired // false')"
    after_secondary_reset_expired="$(json_field "$after_quota_json" '.snapshot.secondary_reset_expired // false')"
    after_primary_bucket_current="$(json_field "$after_quota_json" '.snapshot.primary_bucket_current // false')"
    after_secondary_bucket_current="$(json_field "$after_quota_json" '.snapshot.secondary_bucket_current // false')"
    after_model_hint="$(json_field "$after_quota_json" '.snapshot.model_hint // "unknown"')"
    after_primary="$(json_field "$after_quota_json" '.snapshot.primary_used_percent')"
    after_secondary="$(json_field "$after_quota_json" '.snapshot.secondary_used_percent')"
    after_primary_reset="$(json_field "$after_quota_json" '.snapshot.primary_resets_at')"
    after_secondary_reset="$(json_field "$after_quota_json" '.snapshot.secondary_resets_at')"
    after_primary_left="$(awk -v used="$after_primary" 'BEGIN { printf "%.1f", 100 - used }')"
    after_secondary_left="$(awk -v used="$after_secondary" 'BEGIN { printf "%.1f", 100 - used }')"
    if [[ "$after_selection" == "exact_model" ]]; then
      after_primary_guardrail_decision="$(quota_bucket_decision "$after_primary_bucket_current" "$after_primary_left" "$five_hour_threshold")"
      after_secondary_guardrail_decision="$(quota_bucket_decision "$after_secondary_bucket_current" "$after_secondary_left" "$week_threshold")"
    fi
    log_line "INFO" "quota.after execution_origin=$CODEX_EXECUTION_ORIGIN target_model=$CODEX_MODEL snapshot_selection=$after_selection snapshot_current=$after_snapshot_is_current snapshot_stale_after_reset=$after_snapshot_stale_after_reset primary_reset_expired=$after_primary_reset_expired secondary_reset_expired=$after_secondary_reset_expired primary_bucket_current=$after_primary_bucket_current secondary_bucket_current=$after_secondary_bucket_current limit_id=$after_limit_id limit_name=$(shell_quote "$after_limit_name") plan_type=$after_plan_type source=$after_source snapshot_model_hint=$after_model_hint event_timestamp=$after_ts snapshot_age_seconds=$after_snapshot_age_seconds primary_used=${after_primary}% primary_left=${after_primary_left}% primary_decision=$after_primary_guardrail_decision primary_reset_age_seconds=$after_primary_reset_age_seconds secondary_used=${after_secondary}% secondary_left=${after_secondary_left}% secondary_decision=$after_secondary_guardrail_decision secondary_reset_age_seconds=$after_secondary_reset_age_seconds"
  else
    after_primary=""
    after_secondary=""
    after_primary_reset=""
    after_secondary_reset=""
    after_primary_left=""
    after_secondary_left=""
    after_snapshot_age_seconds=""
    after_primary_reset_age_seconds=""
    after_secondary_reset_age_seconds=""
    after_snapshot_stale_after_reset=""
    after_primary_reset_expired=""
    after_secondary_reset_expired=""
    after_primary_bucket_current=""
    after_secondary_bucket_current=""
    log_line "WARN" "quota.after unavailable"
  fi

  local observed_primary_delta observed_secondary_delta observed_delta_status
  local quota_snapshot_identity_changed
  quota_snapshot_identity_changed="$(quota_identity_changed_flag "${limit_id:-unknown}" "${limit_name:-unknown}" "${after_limit_id:-unknown}" "${after_limit_name:-unknown}")"
  if [[ -n "$after_primary" && -n "$after_secondary" && "$primary_reset" == "$after_primary_reset" && "$secondary_reset" == "$after_secondary_reset" ]]; then
    observed_primary_delta="$(awk -v before="$primary_used" -v after="$after_primary" 'BEGIN { printf "%.1f", after - before }')"
    observed_secondary_delta="$(awk -v before="$secondary_used" -v after="$after_secondary" 'BEGIN { printf "%.1f", after - before }')"
    observed_delta_status="same_window"
  elif [[ -n "$after_primary" && -n "$after_secondary" ]]; then
    observed_primary_delta="unavailable"
    observed_secondary_delta="unavailable"
    observed_delta_status="reset_changed"
    log_line "WARN" "quota.jump execution_origin=$CODEX_EXECUTION_ORIGIN target_model=$CODEX_MODEL status=non_authoritative observed_delta_status=$observed_delta_status quota_identity_changed=$quota_snapshot_identity_changed before_limit_id=${limit_id:-unknown} after_limit_id=${after_limit_id:-unknown} before_limit_name=$(shell_quote "${limit_name:-unknown}") after_limit_name=$(shell_quote "${after_limit_name:-unknown}") $(quota_transition_fields "$primary_used" "$primary_left" "$secondary_used" "$secondary_left" "$after_primary" "$after_primary_left" "$after_secondary" "$after_secondary_left") before_primary_reset=$(format_epoch_local "$primary_reset") after_primary_reset=$(format_epoch_local "$after_primary_reset") before_secondary_reset=$(format_epoch_local "$secondary_reset") after_secondary_reset=$(format_epoch_local "$after_secondary_reset") before_source=${before_source:-unknown} after_source=${after_source:-unknown}"
  else
    observed_primary_delta="unavailable"
    observed_secondary_delta="unavailable"
    observed_delta_status="after_snapshot_unavailable"
  fi

  local status_marker status_marker_analysis status_marker_source
  local status_marker_candidate status_marker_candidate_marker status_marker_candidate_rejection_reason
  local session_end_state
  local primary_session_diagnostics
  local primary_session_agent_message_count primary_session_tool_call_count primary_session_tool_result_count
  local primary_session_task_complete_last_agent_message
  local primary_session_last_rate_limit_reached_type primary_session_last_rate_limit_limit_id primary_session_last_rate_limit_limit_name primary_session_last_rate_limit_plan_type
  local primary_session_last_rate_limit_primary_used_percent primary_session_last_rate_limit_secondary_used_percent
  local quota_session_identity_changed
  local primary_failure_classification
  local post_run_should_stop=0
  local post_run_stop_reason=""
  status_marker_analysis="$(while_marker_analysis_json "$last_message_file")"
  status_marker_candidate="$(json_field "$status_marker_analysis" '.candidate_line')"
  status_marker_candidate_marker="$(json_field "$status_marker_analysis" '.candidate_marker')"
  status_marker_candidate_rejection_reason="$(json_field "$status_marker_analysis" '.candidate_rejection_reason')"
  session_end_state="$(parse_session_end_state "${after_source:-}")"
  primary_session_diagnostics="$(session_diagnostics_json "${after_source:-}")"
  primary_session_agent_message_count="$(json_field "$primary_session_diagnostics" '.agent_message_count')"
  primary_session_tool_call_count="$(json_field "$primary_session_diagnostics" '.tool_call_count')"
  primary_session_tool_result_count="$(json_field "$primary_session_diagnostics" '.tool_result_count')"
  primary_session_task_complete_last_agent_message="$(json_field "$primary_session_diagnostics" '.task_complete_last_agent_message')"
  primary_session_last_rate_limit_reached_type="$(json_field "$primary_session_diagnostics" '.last_rate_limit_reached_type')"
  primary_session_last_rate_limit_limit_id="$(json_field "$primary_session_diagnostics" '.last_rate_limit_limit_id')"
  primary_session_last_rate_limit_limit_name="$(json_field "$primary_session_diagnostics" '.last_rate_limit_limit_name')"
  primary_session_last_rate_limit_plan_type="$(json_field "$primary_session_diagnostics" '.last_rate_limit_plan_type')"
  primary_session_last_rate_limit_primary_used_percent="$(json_field "$primary_session_diagnostics" '.last_rate_limit_primary_used_percent')"
  primary_session_last_rate_limit_secondary_used_percent="$(json_field "$primary_session_diagnostics" '.last_rate_limit_secondary_used_percent')"
  quota_session_identity_changed="$(quota_identity_changed_flag "${limit_id:-unknown}" "${limit_name:-unknown}" "$primary_session_last_rate_limit_limit_id" "$primary_session_last_rate_limit_limit_name")"
  status_marker="$(resolved_status_marker_from_analysis "$status_marker_analysis" "$codex_exit" "$primary_session_task_complete_last_agent_message")"
  if [[ -n "$(json_field "$status_marker_analysis" '.accepted_marker')" ]]; then
    status_marker_source="exact"
  elif [[ -n "$status_marker" ]]; then
    status_marker_source="recovered_malformed_candidate"
    log_line "WARN" "status_marker.candidate_recovered marker=$status_marker candidate_marker=$status_marker_candidate_marker reason=$status_marker_candidate_rejection_reason candidate=$(shell_quote "$status_marker_candidate") codex_exit=$codex_exit task_complete_last_agent_message=$primary_session_task_complete_last_agent_message"
  elif [[ -n "$status_marker_candidate" ]]; then
    status_marker_source="rejected_malformed_candidate"
    log_line "WARN" "status_marker.candidate_rejected candidate_marker=$status_marker_candidate_marker reason=$status_marker_candidate_rejection_reason candidate=$(shell_quote "$status_marker_candidate") codex_exit=$codex_exit task_complete_last_agent_message=$primary_session_task_complete_last_agent_message"
  else
    status_marker_source="missing"
  fi
  primary_failure_classification="none"
  log_line "INFO" "cycle.summary execution_origin=$CODEX_EXECUTION_ORIGIN model=$CODEX_MODEL observed_primary_delta=$observed_primary_delta observed_secondary_delta=$observed_secondary_delta observed_delta_status=$observed_delta_status status_marker=${status_marker:-missing} status_marker_source=$status_marker_source session_end_state=$session_end_state agent_messages=$primary_session_agent_message_count tool_calls=$primary_session_tool_call_count tool_results=$primary_session_tool_result_count task_complete_last_agent_message=$primary_session_task_complete_last_agent_message codex_exit=$codex_exit"
  log_review_report_summary "$last_message_file" "${status_marker:-missing}" "$codex_exit"

  if [[ "$after_selection" == "exact_model" ]]; then
    if [[ "$after_primary_guardrail_decision" == "stop" ]]; then
      post_run_should_stop=1
      post_run_stop_reason="post-run 5-hour left ${after_primary_left}% <= ${five_hour_threshold}%"
    fi
    if [[ "$after_secondary_guardrail_decision" == "stop" ]]; then
      post_run_should_stop=1
      if [[ -n "$post_run_stop_reason" ]]; then
        post_run_stop_reason="$post_run_stop_reason; "
      fi
      post_run_stop_reason="${post_run_stop_reason}post-run weekly left ${after_secondary_left}% <= ${week_threshold}% (base ${CODEX_WEEK_STOP_PERCENT}% + buffer ${week_buffer}%)"
    fi
    if [[ "$after_primary_guardrail_decision" == "defer" && "$after_secondary_guardrail_decision" == "defer" ]]; then
      log_line "WARN" "quota.guardrails phase=after_run target_model=$CODEX_MODEL deferred reason=stale_snapshot_after_reset snapshot_current=$after_snapshot_is_current snapshot_stale_after_reset=${after_snapshot_stale_after_reset:-unknown} primary_bucket_current=${after_primary_bucket_current:-unknown} secondary_bucket_current=${after_secondary_bucket_current:-unknown} primary_reset=$(format_epoch_local "$after_primary_reset") primary_reset_age_seconds=${after_primary_reset_age_seconds:-unknown} secondary_reset=$(format_epoch_local "$after_secondary_reset") secondary_reset_age_seconds=${after_secondary_reset_age_seconds:-unknown}"
    elif [[ "$after_primary_guardrail_decision" == "defer" || "$after_secondary_guardrail_decision" == "defer" ]]; then
      log_line "WARN" "quota.guardrails phase=after_run target_model=$CODEX_MODEL partial_decision primary_decision=$after_primary_guardrail_decision secondary_decision=$after_secondary_guardrail_decision primary_bucket_current=${after_primary_bucket_current:-unknown} secondary_bucket_current=${after_secondary_bucket_current:-unknown} primary_reset_expired=${after_primary_reset_expired:-unknown} secondary_reset_expired=${after_secondary_reset_expired:-unknown}"
    fi
  fi

  if [[ "$post_run_should_stop" -eq 1 ]]; then
    if [[ "$codex_exit" -ne 0 ]]; then
      ensure_codex_session_store_writable_or_exit "after_run" "1"
      ensure_codex_arg0_tmp_clean_or_exit "after_run" "1"
      ensure_codex_bwrap_tmp_writable_or_exit "after_run" "1"
    fi
    if [[ "$codex_exit" -ne 0 && -z "$status_marker" && "$session_end_state" == "no_agent_message" ]]; then
      primary_failure_classification="PRIMARY_NO_AGENT_MESSAGE_AFTER_QUOTA_EXHAUSTION"
      log_line "WARN" "primary.failure_classification classification=$primary_failure_classification phase=after_run codex_exit=$codex_exit status_marker=missing session_end_state=$session_end_state agent_messages=$primary_session_agent_message_count tool_calls=$primary_session_tool_call_count quota_identity_changed=$quota_session_identity_changed before_limit_id=${limit_id:-unknown} after_limit_id=${after_limit_id:-unknown} session_limit_id=$primary_session_last_rate_limit_limit_id $(quota_transition_fields "$primary_used" "$primary_left" "$secondary_used" "$secondary_left" "$after_primary" "$after_primary_left" "$after_secondary" "$after_secondary_left") observed_delta_status=$observed_delta_status rate_limit_reached_type=$primary_session_last_rate_limit_reached_type"
      log_line "WARN" "primary.no_agent_quota_exhausted classification=$primary_failure_classification phase=after_run codex_exit=$codex_exit status_marker=missing session_end_state=$session_end_state session_source=${after_source:-unknown} quota_identity_changed=$quota_session_identity_changed before_limit_id=${limit_id:-unknown} after_limit_id=${after_limit_id:-unknown} session_limit_id=$primary_session_last_rate_limit_limit_id before_limit_name=$(shell_quote "${limit_name:-unknown}") after_limit_name=$(shell_quote "${after_limit_name:-unknown}") session_limit_name=$(shell_quote "$primary_session_last_rate_limit_limit_name") session_primary_used=${primary_session_last_rate_limit_primary_used_percent}% session_secondary_used=${primary_session_last_rate_limit_secondary_used_percent}% $(quota_transition_fields "$primary_used" "$primary_left" "$secondary_used" "$secondary_left" "$after_primary" "$after_primary_left" "$after_secondary" "$after_secondary_left") observed_delta_status=$observed_delta_status fallback_child_id=pending"
      write_primary_quota_blocked_marker "$post_run_stop_reason codex_exit=$codex_exit status_marker=missing session_end_state=$session_end_state classification=$primary_failure_classification" "after_run"
    fi
    if [[ "$CODEX_ATTEMPT_ROLE" == "primary" && "$CODEX_FALLBACK_ON_PRIMARY_QUOTA" == "1" ]] && fallback_available; then
      local fallback_exit
      run_fallback_cycle "primary_quota_after_run" "$post_run_stop_reason codex_exit=$codex_exit status_marker=${status_marker:-missing} session_end_state=$session_end_state classification=$primary_failure_classification"
      fallback_exit=$?
      if [[ "$primary_failure_classification" == "PRIMARY_NO_AGENT_MESSAGE_AFTER_QUOTA_EXHAUSTION" ]]; then
        local fallback_child_id fallback_child_marker
        fallback_child_id="$(read_artifact_or_unknown "$CODEX_POSTMORTEM_DIR/$CYCLE_ID/screen/current-child-cycle-id.txt")"
        fallback_child_marker="$(json_field "$(while_marker_analysis_json "${FALLBACK_SCREEN_TRANSCRIPT_PATH:-}")" '.accepted_marker')"
        [[ -n "$fallback_child_marker" ]] || fallback_child_marker="missing"
        log_line "INFO" "primary.no_agent_quota_exhausted.fallback child_exit=$fallback_exit fallback_child_id=$fallback_child_id fallback_child_marker=$fallback_child_marker fallback_screen_session=${FALLBACK_SCREEN_SESSION_NAME:-none}"
      fi
      finish_cycle "$fallback_exit" FALLBACK_CHAIN_EXIT INFO "trigger=primary_quota_after_run final_exit=$fallback_exit target_model=$CODEX_FALLBACK_MODEL postmortem_status=$POSTMORTEM_SEQUENCE_STATUS report_path=${POSTMORTEM_REPORT_PATH:-none}"
    fi
    log_line "WARN" "quota.stop phase=after_run reason=\"$post_run_stop_reason\" codex_exit=$codex_exit status_marker=${status_marker:-missing}"
    if stop_parent_loop; then
      finish_cycle "$CODEX_GUARDRAIL_STOP_EXIT_CODE" QUOTA_GUARDRAIL_STOP_AFTER_RUN INFO "status_marker=${status_marker:-missing} codex_exit=$codex_exit execution_origin=$CODEX_EXECUTION_ORIGIN"
    fi
    log_line "ERROR" "cycle.stop failed to confirm parent loop termination after run"
    finish_cycle 4 QUOTA_GUARDRAIL_STOP_FAILED_AFTER_RUN ERROR "status_marker=${status_marker:-missing} codex_exit=$codex_exit"
  fi

  case "$status_marker" in
    WORK_DONE)
      finish_cycle 0 WORK_DONE INFO "codex_exit=$codex_exit"
      ;;
    NO_BACKEND_TASK)
      if [[ "$DIRTY_PATH_COUNT" -gt 0 ]]; then
        if [[ "$CODEX_ATTEMPT_ROLE" == "primary" && "$CODEX_FALLBACK_ON_DIRTY_NO_BACKEND_TASK" == "1" ]] && fallback_available; then
          local fallback_exit
          run_fallback_cycle "dirty_no_backend_task" "dirty_paths=$DIRTY_PATH_COUNT tracked_modified_paths=$TRACKED_MODIFIED_PATH_COUNT untracked_paths=$UNTRACKED_PATH_COUNT"
          fallback_exit=$?
          finish_cycle "$fallback_exit" FALLBACK_CHAIN_EXIT INFO "trigger=dirty_no_backend_task final_exit=$fallback_exit target_model=$CODEX_FALLBACK_MODEL postmortem_status=$POSTMORTEM_SEQUENCE_STATUS report_path=${POSTMORTEM_REPORT_PATH:-none}"
        fi
        log_line "WARN" "cycle.stop no backend task reported on a dirty worktree; treating this as a soft miss and continuing the outer loop"
        finish_cycle 0 NO_BACKEND_TASK_DIRTY_CONTINUE WARN "dirty_paths=$DIRTY_PATH_COUNT tracked_modified_paths=$TRACKED_MODIFIED_PATH_COUNT untracked_paths=$UNTRACKED_PATH_COUNT codex_exit=$codex_exit"
      fi
      if [[ "$CODEX_CONTINUE_ON_NO_BACKEND_TASK" == "1" ]]; then
        log_line "INFO" "cycle.stop no clear backend task remained; continuing outer loop because CODEX_CONTINUE_ON_NO_BACKEND_TASK=1"
        finish_cycle 0 NO_BACKEND_TASK_CONTINUE INFO "codex_exit=$codex_exit"
      fi
      log_line "INFO" "cycle.stop no clear backend task remained; exiting 5 to stop the outer loop intentionally"
      finish_cycle 5 NO_BACKEND_TASK INFO "stop_outer_loop=1 codex_exit=$codex_exit"
      ;;
    BLOCKED)
      if [[ "$CODEX_ATTEMPT_ROLE" == "primary" && "$CODEX_FALLBACK_ON_BLOCKED" == "1" ]] && fallback_available; then
        local fallback_exit
        run_fallback_cycle "blocked" "codex_exit=$codex_exit"
        fallback_exit=$?
        finish_cycle "$fallback_exit" FALLBACK_CHAIN_EXIT INFO "trigger=blocked final_exit=$fallback_exit target_model=$CODEX_FALLBACK_MODEL postmortem_status=$POSTMORTEM_SEQUENCE_STATUS report_path=${POSTMORTEM_REPORT_PATH:-none}"
      fi
      finish_cycle 2 BLOCKED WARN "codex_exit=$codex_exit"
      ;;
    *)
      if [[ "$codex_exit" -ne 0 ]]; then
        ensure_codex_session_store_writable_or_exit "after_run" "1"
        ensure_codex_arg0_tmp_clean_or_exit "after_run" "1"
        ensure_codex_bwrap_tmp_writable_or_exit "after_run" "1"
      fi
      if [[ "$CODEX_ATTEMPT_ROLE" == "primary" && "$CODEX_FALLBACK_ON_FAILURE" == "1" ]] && fallback_available; then
        local fallback_exit
        run_fallback_cycle "failure" "codex_exit=$codex_exit session_end_state=$session_end_state status_marker=${status_marker:-missing} status_marker_source=$status_marker_source"
        fallback_exit=$?
        finish_cycle "$fallback_exit" FALLBACK_CHAIN_EXIT INFO "trigger=failure final_exit=$fallback_exit target_model=$CODEX_FALLBACK_MODEL postmortem_status=$POSTMORTEM_SEQUENCE_STATUS report_path=${POSTMORTEM_REPORT_PATH:-none}"
      fi
      if [[ "$codex_exit" -ne 0 ]]; then
        if [[ "$session_end_state" == turn_aborted:* ]]; then
          log_line "WARN" "codex turn aborted without an UPKEEPER_STATUS marker reason=${session_end_state#turn_aborted:}"
          finish_cycle 6 TURN_ABORTED_WITHOUT_MARKER WARN "reason=${session_end_state#turn_aborted:} codex_exit=$codex_exit"
        fi
        log_line "ERROR" "codex exited non-zero without an UPKEEPER_STATUS marker"
      else
        log_line "ERROR" "missing UPKEEPER_STATUS marker in Codex final response"
      fi
      finish_cycle 3 MISSING_STATUS_MARKER ERROR "codex_exit=$codex_exit session_end_state=$session_end_state status_marker_source=$status_marker_source"
      ;;
  esac
}

# Allow safe sourcing in focused backend validation runs; only execute the wrapper
# when this file is the top-level script entrypoint.
if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
  trap 'handle_wrapper_signal INT' INT
  trap 'handle_wrapper_signal TERM' TERM
  trap 'handle_wrapper_signal HUP' HUP
  main "$@"
fi
