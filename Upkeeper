  [[ -n "$limit_name" && "$limit_name" != "null" ]] || limit_name="unknown"

  if is_spark_model "$target_model"; then
    if [[ "$limit_id" == codex_* || "$limit_name" == *spark* || "$limit_name" == *Spark* || "$limit_name" == *SPARK* ]]; then
