upkeeper_postmortem_report_summary_for_hardening() {
  local report_path="${1:-}"
  local report_present="0"
  local report_sha="missing"
  local report_lines="0"
  local report_bytes="0"
  local report_headings="(missing)"
  local hardening_marker="missing"

  if [[ -s "$report_path" ]]; then
    report_present="1"
    report_sha="$(postmortem_file_sha256 "$report_path")"
    report_lines="$(wc -l <"$report_path" | tr -d ' ')"
    report_bytes="$(wc -c <"$report_path" | tr -d ' ')"
    hardening_marker="$(parse_postmortem_marker "$report_path")"
    report_headings="$(python3 - "$report_path" <<'PY'
import re
import sys

path = sys.argv[1]
headings = []

try:
    with open(path, "r", encoding="utf-8", errors="replace") as handle:
        for raw_line in handle:
            line = raw_line.strip()
            if not line.startswith("## "):
                continue
            title = line[3:].strip()
            title = re.sub(r"\s+", " ", title)
            title = re.sub(r"[^A-Za-z0-9 ._:/-]", "_", title)
            title = title[:80].strip()
            if not title:
                title = "(blank)"
            headings.append(title)
            if len(headings) >= 6:
                break
except OSError:
    headings = ["(missing)"]

if not headings:
    headings = ["(none)"]

print("; ".join(headings))
PY
    )"
    report_headings="$(upkeeper_prompt_safe_inline_value "$report_headings" "(none)")"
    hardening_marker="$(upkeeper_prompt_safe_inline_value "${hardening_marker:-missing}" "missing")"
  fi

  printf 'report_present=%s report_sha256=%s report_lines=%s report_bytes=%s hardening_marker=%s report_headings=%s' \
    "$report_present" \
    "$report_sha" \
    "$report_lines" \
    "$report_bytes" \
    "$hardening_marker" \
    "$report_headings"
}

