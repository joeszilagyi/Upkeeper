# Main cycle.
#
# Order matters:
# 1. establish local evidence paths and current worktree state,
# 2. read quota state before spending anything,
# 3. run exactly one Codex task when guardrails allow it,
# 4. classify the model's final marker,
# 5. hand off to bounded fallback/postmortem only when that reduces risk.
main() {
  apply_configured_cli_defaults
  validate_codex_mode_args_or_exit
  parse_args "$@"
  ensure_log_parent
  ensure_log_writable_or_exit "startup"
  require_commands
  normalize_guardrail_thresholds
  check_central_wrapper_health_or_exit
  acquire_active_lock_or_exit
  trap cleanup_run_temp_files EXIT
  ensure_operator_guide
  resolve_prompt_file
  scan_previous_run_anomalies
  rotate_wrapper_log_if_needed
  refresh_worktree_counts

  local direct_parent_pid direct_parent_comm direct_parent_args
  if details="$(direct_parent_details)"; then
    IFS=$'\t' read -r direct_parent_pid direct_parent_comm direct_parent_args <<<"$details"
  else
    direct_parent_pid="unknown"
    direct_parent_comm="unknown"
    direct_parent_args="unknown"
  fi
  local wrapper_start_fingerprint direct_parent_start_fingerprint
  wrapper_start_fingerprint="$(process_start_fingerprint "$$")"
  direct_parent_start_fingerprint="$(process_start_fingerprint "$direct_parent_pid")"

  local loop_parent_pid loop_parent_comm loop_parent_args loop_parent_override
  if details="$(parent_shell_details)"; then
    IFS=$'\t' read -r loop_parent_pid loop_parent_comm loop_parent_args loop_parent_override <<<"$details"
  else
    loop_parent_pid="unknown"
    loop_parent_comm="unknown"
    loop_parent_args="unknown"
    loop_parent_override="0"
  fi
  local loop_parent_start_fingerprint
  loop_parent_start_fingerprint="$(process_start_fingerprint "$loop_parent_pid")"

  log_line "INFO" "cycle.start execution_origin=$(shell_quote "$CODEX_EXECUTION_ORIGIN") script=$(shell_quote "$SELF_INVOKE_PATH") implementation=$(shell_quote "$SELF_PATH") cwd=$(shell_quote "$ROOT_DIR") pid=$$ wrapper_start=$wrapper_start_fingerprint ppid=$direct_parent_pid parent_comm=$(shell_quote "$direct_parent_comm") parent_start=$direct_parent_start_fingerprint loop_parent_pid=$loop_parent_pid loop_parent_comm=$(shell_quote "$loop_parent_comm") loop_parent_start=$loop_parent_start_fingerprint loop_parent_override=$loop_parent_override config_loaded=$UPKEEPER_CONFIG_LOADED config_file=$(shell_quote "$UPKEEPER_CONFIG_SOURCE") model=$(shell_quote "$CODEX_MODEL") effort=$(shell_quote "$CODEX_REASONING_EFFORT") mode=$(shell_quote "$CODEX_MODE_STRING") model_override=$(shell_quote "${CODEX_MODEL_OVERRIDE_SPEC:-none}") model_override_applied=$CODEX_MODEL_OVERRIDE_APPLIED target_file=$(shell_quote "${CODEX_TARGET_FILE:-none}") target_root=$(shell_quote "${CODEX_TARGET_ROOT:-none}") target_depth=$(shell_quote "${CODEX_TARGET_MAX_DEPTH:-none}") selection_source=$(shell_quote "$CODEX_SELECTION_SOURCE") selection_order=$(shell_quote "$CODEX_SELECTION_ORDER") manifest_mode=$(shell_quote "$CODEX_FILE_MANIFEST_MODE") manifest_path=$(shell_quote "$CODEX_FILE_MANIFEST_PATH") include_globs=$(shell_quote "${CODEX_SELECTION_INCLUDE_GLOBS:-none}") exclude_globs=$(shell_quote "${CODEX_SELECTION_EXCLUDE_GLOBS:-none}") selection_review_modules=$(shell_quote "${CODEX_SELECTION_REVIEW_MODULES:-none}") prompt_pass=$(shell_quote "${CODEX_PROMPT_PASS:-default}") review_modules=$(review_modules_csv) attempt_role=$(shell_quote "$CODEX_ATTEMPT_ROLE") fallback_chain_active=$CODEX_FALLBACK_CHAIN_ACTIVE primary_model_context=$(shell_quote "${CODEX_PRIMARY_MODEL_CONTEXT:-none}") fallback_trigger=$(shell_quote "${CODEX_FALLBACK_TRIGGER:-none}") screen_fallback_child_id=$(shell_quote "${CODEX_SCREEN_FALLBACK_CHILD_ID:-none}") code_home=$(shell_quote "$CODEX_HOME_DIR") dry_run=$UPKEEPER_DRY_RUN continue_on_no_backend_task=$CODEX_CONTINUE_ON_NO_BACKEND_TASK boot_id=$(system_boot_id) uptime_seconds=$(system_uptime_seconds) dirty_paths=$DIRTY_PATH_COUNT tracked_modified_paths=$TRACKED_MODIFIED_PATH_COUNT untracked_paths=$UNTRACKED_PATH_COUNT"
  start_run_mark_heartbeat
  check_disk_space_preflight
  if [[ "$STARTUP_ANOMALY_GATE" == "1" ]]; then
    log_line "WARN" "startup_anomaly.gate status=active reasons=$(shell_quote "${STARTUP_ANOMALY_REASONS:-unknown}") force_upkeeper=$CODEX_STARTUP_ANOMALY_FORCE_UPKEEPER action=block_normal_selection_until_upkeeper_suite_checked"
    if ! write_startup_anomaly_gate_state "unresolved" "active_at_startup"; then
      finish_cycle 7 STARTUP_ANOMALY_STATE_UNWRITABLE ERROR "codex_exec_started=0"
    fi
    enforce_startup_anomaly_gate_target_or_exit
  fi

  enforce_primary_quota_block_marker
  ensure_file_manifest_for_selection

  local quota_json
  quota_json="$(quota_state_json)"

  local before_error before_ts before_source before_model_hint before_selection before_matching_snapshot_count before_snapshot_is_current
  local before_snapshot_age_seconds before_primary_reset_age_seconds before_secondary_reset_age_seconds before_snapshot_stale_after_reset
