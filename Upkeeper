upkeeper_config_fail() {
  printf 'Upkeeper: %s\n' "$*" >&2
  exit 3
}

resolve_upkeeper_config_path() {
  local raw_path="$1"

  case "$raw_path" in
    /*)
      printf '%s' "$raw_path"
      ;;
    *)
      printf '%s/%s' "$ROOT_DIR" "$raw_path"
      ;;
  esac
}

upkeeper_config_path_mode() {
  local path="$1"
  local mode=""

  if mode="$(stat -Lc '%a' "$path" 2>/dev/null)"; then
    printf '%s' "$mode"
    return 0
  fi
  if mode="$(stat -f '%Lp' "$path" 2>/dev/null)"; then
    printf '%s' "$mode"
    return 0
  fi
  if command -v python3 >/dev/null 2>&1; then
    python3 - "$path" <<'PY'
import os
import stat
import sys

print(oct(stat.S_IMODE(os.lstat(sys.argv[1]).st_mode))[2:])
PY
    return $?
  fi

  return 1
}

upkeeper_config_content_hash() {
  local path="$1"
  local digest=""

  if command -v sha256sum >/dev/null 2>&1 && digest="$(sha256sum "$path" 2>/dev/null)"; then
    digest="${digest%% *}"
    printf 'sha256:%s' "$digest"
    return 0
  fi
  if command -v shasum >/dev/null 2>&1 && digest="$(shasum -a 256 "$path" 2>/dev/null)"; then
    digest="${digest%% *}"
    printf 'sha256:%s' "$digest"
    return 0
  fi
  if command -v python3 >/dev/null 2>&1; then
    python3 - "$path" <<'PY'
import hashlib
import sys

digest = hashlib.sha256()
with open(sys.argv[1], "rb") as handle:
    for chunk in iter(lambda: handle.read(65536), b""):
        digest.update(chunk)
print(f"sha256:{digest.hexdigest()}")
PY
    return $?
  fi

  return 1
}

upkeeper_config_trim_whitespace() {
  local value="$1"

  value="${value#"${value%%[![:space:]]*}"}"
  value="${value%"${value##*[![:space:]]}"}"
  printf '%s' "$value"
}

upkeeper_config_safe_value_expr() {
  local expr="$1"
  local context="$2"

  case "$expr" in
    *$'\n'*|*$'\r'*|*'`'*|*'$('*|*';'*|*'&'*|*'|'*|*'<'*|*'>'*|*'\\'*|*'"'*|*':='*)
      upkeeper_config_fail "unsupported config expression in $context"
      ;;
  esac
}

upkeeper_config_expand_safe_value() {
  local expr="$1"
  local context="$2"
  local expanded=""

  upkeeper_config_safe_value_expr "$expr" "$context"
  eval "expanded=\"$expr\"" || upkeeper_config_fail "unable to expand config expression in $context"
  printf '%s' "$expanded"
}

upkeeper_config_parse_assignment_value() {
  local raw_value="$1"
  local context="$2"

  if [[ "$raw_value" =~ ^\"(.*)\"$ ]]; then
    upkeeper_config_expand_safe_value "${BASH_REMATCH[1]}" "$context"
    return 0
  fi
  if [[ "$raw_value" =~ ^\'(.*)\'$ ]]; then
    printf '%s' "${BASH_REMATCH[1]}"
    return 0
  fi

  upkeeper_config_expand_safe_value "$raw_value" "$context"
}

upkeeper_load_assignment_file() {
  local file_path="$1"
  local file_label="$2"
  local line=""
  local trimmed=""
  local value_context=""
  local line_number=0
  local variable_name=""
  local raw_value=""
  local parsed_value=""
  local export_requested="0"

  while IFS= read -r line || [[ -n "$line" ]]; do
    line_number=$((line_number + 1))
    trimmed="$(upkeeper_config_trim_whitespace "$line")"
    [[ -z "$trimmed" || "${trimmed:0:1}" == "#" ]] && continue

    value_context="$file_label line=$line_number path=$file_path"
    if [[ "$trimmed" =~ ^:[[:space:]]*\"\$\{([A-Za-z_][A-Za-z0-9_]*)\:\=(.*)\}\"[[:space:]]*$ ]]; then
      variable_name="${BASH_REMATCH[1]}"
      raw_value="${BASH_REMATCH[2]}"
      if ! [[ -v "$variable_name" ]] || [[ -z "${!variable_name-}" ]]; then
        parsed_value="$(upkeeper_config_parse_assignment_value "$raw_value" "$value_context")"
        printf -v "$variable_name" '%s' "$parsed_value"
      fi
      continue
    fi

    export_requested="0"
    if [[ "$trimmed" =~ ^export[[:space:]]+([A-Za-z_][A-Za-z0-9_]*)=(.*)$ ]]; then
      export_requested="1"
      variable_name="${BASH_REMATCH[1]}"
      raw_value="${BASH_REMATCH[2]}"
    elif [[ "$trimmed" =~ ^([A-Za-z_][A-Za-z0-9_]*)=(.*)$ ]]; then
      variable_name="${BASH_REMATCH[1]}"
      raw_value="${BASH_REMATCH[2]}"
    else
      upkeeper_config_fail "unsupported config syntax in $file_label line=$line_number path=$file_path"
    fi

    parsed_value="$(upkeeper_config_parse_assignment_value "$raw_value" "$value_context")"
    printf -v "$variable_name" '%s' "$parsed_value"
    [[ "$export_requested" == "1" ]] && export "$variable_name"
  done < "$file_path"
  return 0
}

upkeeper_config_assert_trusted_path() {
  local config_path="$1"
  local reject_group_writable="${2:-1}"
  local component=""
  local segment=""
  local remainder=""
  local mode=""

  [[ "$config_path" == /* ]] || upkeeper_config_fail "config file path must be absolute after resolution: $config_path"
  [[ -L "$config_path" ]] && upkeeper_config_fail "config file must not be a symlink: $config_path"
  [[ -O "$config_path" ]] || upkeeper_config_fail "config file must be owned by the current user: $config_path"

  remainder="${config_path#/}"
  component="/"
  while [[ -n "$remainder" ]]; do
    segment="${remainder%%/*}"
    if [[ "$component" == "/" ]]; then
      component="/$segment"
    else
      component="$component/$segment"
    fi

    [[ -L "$component" ]] && upkeeper_config_fail "config path must not include symlink components: $component"
    mode="$(upkeeper_config_path_mode "$component")" || upkeeper_config_fail "unable to inspect config path permissions: $component"
    if [[ "$reject_group_writable" == "1" ]]; then
      (( (8#$mode & 022) == 0 )) || upkeeper_config_fail "config path must not be group/world-writable: $component mode=$mode"
    else
      (( (8#$mode & 002) == 0 )) || upkeeper_config_fail "config path must not be world-writable: $component mode=$mode"
    fi

    if [[ "$remainder" == */* ]]; then
      remainder="${remainder#*/}"
    else
      remainder=""
    fi
  done
}

preparse_upkeeper_config_args() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --config-file=*)
        UPKEEPER_CONFIG_FILE="${1#*=}"
        [[ -n "$UPKEEPER_CONFIG_FILE" ]] || upkeeper_config_fail "--config-file requires a value"
        UPKEEPER_CONFIG_FILE_EXPLICIT="1"
        ;;
      --config-file)
        upkeeper_config_fail "use --config-file=PATH (spaced form is intentionally unsupported)"
        ;;
      --no-config)
        UPKEEPER_CONFIG_DISABLE="1"
        ;;
    esac
    shift
  done
}

load_upkeeper_config_file() {
  local config_path
  local config_dir
  local reject_group_writable="1"

  [[ "$UPKEEPER_CONFIG_DISABLE" == "1" ]] && return 0
  [[ -n "$UPKEEPER_CONFIG_FILE" ]] || return 0

  config_path="$(resolve_upkeeper_config_path "$UPKEEPER_CONFIG_FILE")"
  if [[ ! -e "$config_path" ]]; then
    [[ "$UPKEEPER_CONFIG_FILE_EXPLICIT" == "1" ]] && upkeeper_config_fail "config file not found: $config_path"
    return 0
  fi
  [[ -f "$config_path" ]] || upkeeper_config_fail "config file is not a regular file: $config_path"
  [[ -r "$config_path" ]] || upkeeper_config_fail "config file is not readable: $config_path"
  # The built-in default config lives inside the checked-out wrapper tree, so
  # keep current checkouts working while rejecting world-writable path hops.
  [[ "$config_path" == "$UPKEEPER_CONFIG_DEFAULT_FILE" ]] && reject_group_writable="0"
  upkeeper_config_assert_trusted_path "$config_path" "$reject_group_writable"
  config_dir="$(cd -P -- "$(dirname -- "$config_path")" && pwd)"
  config_path="$config_dir/$(basename -- "$config_path")"

  UPKEEPER_CONFIG_FILE="$config_path"
  UPKEEPER_CONFIG_LOADED="1"
  UPKEEPER_CONFIG_SOURCE="$config_path"
  UPKEEPER_CONFIG_SOURCE_HASH="$(upkeeper_config_content_hash "$config_path" || printf 'unknown')"
  upkeeper_load_assignment_file "$config_path" "config file"
}

load_upkeeper_local_env_file() {
  local local_env_path

  [[ "$UPKEEPER_LOCAL_ENV_DISABLE" == "1" ]] && return 0
  [[ -n "$UPKEEPER_LOCAL_ENV_FILE" ]] || return 0

  local_env_path="$(resolve_upkeeper_config_path "$UPKEEPER_LOCAL_ENV_FILE")"
  if [[ ! -e "$local_env_path" ]]; then
    return 0
  fi
  [[ -f "$local_env_path" ]] || upkeeper_config_fail "local env file is not a regular file: $local_env_path"
  [[ -r "$local_env_path" ]] || upkeeper_config_fail "local env file is not readable: $local_env_path"
  upkeeper_config_assert_trusted_path "$local_env_path" "1"

  UPKEEPER_LOCAL_ENV_FILE="$local_env_path"
  UPKEEPER_LOCAL_ENV_LOADED="1"
  UPKEEPER_LOCAL_ENV_SOURCE="$local_env_path"
  UPKEEPER_LOCAL_ENV_SOURCE_HASH="$(upkeeper_config_content_hash "$local_env_path" || printf 'unknown')"
  upkeeper_load_assignment_file "$local_env_path" "local env file"
}

load_fallback_cycle_contract() {
  local contract_path="${CODEX_FALLBACK_CONTRACT_PATH:-}"
  local postmortem_root="${CODEX_POSTMORTEM_DIR:-${ROOT_DIR}/runtime/journals/upkeeper-postmortems}"

  [[ "${CODEX_FALLBACK_CHAIN_ACTIVE:-0}" == "1" ]] || return 0
  [[ -n "$contract_path" ]] || return 0

  [[ "$contract_path" == /* ]] || return 1
  [[ -f "$contract_path" ]] || return 1
  [[ -r "$contract_path" ]] || return 1
  [[ -L "$contract_path" ]] && return 1
  case "$contract_path" in
    "$postmortem_root"/*|"$postmortem_root")
      ;;
    *)
      return 1
      ;;
  esac

  # shellcheck source=/dev/null
  source "$contract_path"
}

