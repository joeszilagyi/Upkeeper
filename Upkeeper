  if ! rmdir "$probe_dir" 2>"$err_file"; then
    printf 'probe_dir_cleanup_failed:%s' "$(tr '\n' ' ' <"$err_file")"
    rm -f "$err_file"
    return 1
  fi

  rm -f "$err_file"
  printf 'ok'
  return 0
}

ensure_codex_bwrap_tmp_writable_or_exit() {
