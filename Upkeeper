prepare_fallback_chain_token() {
  local token_fd="${CODEX_FALLBACK_CHAIN_TOKEN_FD:-}"

  if [[ "${CODEX_FALLBACK_CHAIN_ACTIVE:-0}" == "1" ]]; then
    if ! [[ "$token_fd" =~ ^[0-9]+$ ]]; then
      log_line "ERROR" "fallback_chain.token missing_fd"
      finish_cycle 7 UPKEEPER_ACTIVE_LOCK_FAILED ERROR "codex_exec_started=0 reason=missing_fallback_chain_token_fd"
    fi
    if ! IFS= read -r CODEX_FALLBACK_CHAIN_TOKEN <&"$token_fd"; then
      log_line "ERROR" "fallback_chain.token missing_read"
      finish_cycle 7 UPKEEPER_ACTIVE_LOCK_FAILED ERROR "codex_exec_started=0 reason=missing_fallback_chain_token_read"
    fi
    if [[ -z "${CODEX_FALLBACK_CHAIN_TOKEN:-}" ]]; then
      log_line "ERROR" "fallback_chain.token missing_value"
      finish_cycle 7 UPKEEPER_ACTIVE_LOCK_FAILED ERROR "codex_exec_started=0 reason=fallback_chain_token_missing"
    fi
    [[ -n "$token_fd" ]] && eval "exec ${token_fd}<&-" 2>/dev/null || true
    return 0
  fi

  CODEX_FALLBACK_CHAIN_TOKEN="$(generate_fallback_chain_token)"
}

fallback_locked_target_path() {
  if [[ -n "${RUN_SELECTED_REVIEW_PATH:-}" ]]; then
    printf '%s' "$RUN_SELECTED_REVIEW_PATH"
    return 0
  fi
  if [[ -n "${CODEX_TARGET_FILE:-}" ]]; then
    printf '%s' "$CODEX_TARGET_FILE"
    return 0
  fi
  return 1
}

run_locked_fallback_cycle() {
  local trigger="$1"
  shift
  local locked_target=""
  local original_target_file="${CODEX_TARGET_FILE:-}"
  local target_locked=0
  local fallback_rc=0

  if locked_target="$(fallback_locked_target_path)"; then
    if [[ -n "$locked_target" && "$locked_target" != "${CODEX_TARGET_FILE:-}" ]]; then
      CODEX_TARGET_FILE="$locked_target"
      target_locked=1
      log_line "INFO" "fallback.target_lock trigger=$trigger target_file_hash=$(shell_quote "$(cycle_start_metadata_hash "$locked_target")") path_redacted=1 source=run_selected_review_path"
    fi
  fi

  set +e
  run_fallback_cycle "$trigger" "$@"
  fallback_rc=$?
  set -e

  if [[ "$target_locked" == "1" ]]; then
    CODEX_TARGET_FILE="$original_target_file"
  fi

  return "$fallback_rc"
}

if declare -f upkeeper_original_run_fallback_cycle >/dev/null; then
  :
elif ! declare -f run_fallback_cycle >/dev/null; then
  log_line "WARN" "fallback.hardening run_fallback_cycle missing; prompt leakage hardening skipped"
else
  _upkeeper_run_fallback_cycle_def="$(declare -f run_fallback_cycle)"
  if [[ -n "$_upkeeper_run_fallback_cycle_def" ]]; then
    _upkeeper_run_fallback_cycle_def="upkeeper_original_run_fallback_cycle${_upkeeper_run_fallback_cycle_def#run_fallback_cycle}"
    eval "$_upkeeper_run_fallback_cycle_def"
    unset -v _upkeeper_run_fallback_cycle_def
  fi
fi

run_fallback_cycle() {
  upkeeper_materialize_inline_prompt_file
  if [[ -n "${INLINE_PROMPT:-}" || -n "${UPKEEPER_PROMPT:-}" ]]; then
    unset INLINE_PROMPT UPKEEPER_PROMPT
  fi
  upkeeper_original_run_fallback_cycle "$@"
}

# Main cycle.
#
# Order matters:
# 1. establish local evidence paths and current worktree state,
# 2. read quota state before spending anything,
# 3. run exactly one Codex task when guardrails allow it,
# 4. classify the model's final marker,
# 5. hand off to bounded fallback/postmortem only when that reduces risk.
main() {
  apply_configured_cli_defaults
  validate_codex_mode_args_or_exit
  parse_args "$@"
  if upkeeper_internal_current_cycle_log_review_requested; then
    upkeeper_emit_sanitized_current_cycle_log_review
    return 0
  fi
  ensure_log_parent
  ensure_log_writable_or_exit "startup"
  require_commands
  normalize_guardrail_thresholds
  check_central_wrapper_health_or_exit
  prepare_fallback_chain_token
  acquire_active_lock_or_exit
  trap cleanup_run_temp_files EXIT
  ensure_operator_guide
  resolve_prompt_file
  scan_previous_run_anomalies
  rotate_wrapper_log_if_needed
  refresh_worktree_counts

  local direct_parent_pid direct_parent_comm direct_parent_summary
  if details="$(direct_parent_details)"; then
    IFS=$'\t' read -r direct_parent_pid direct_parent_comm direct_parent_summary <<<"$details"
  else
    direct_parent_pid="unknown"
    direct_parent_comm="unknown"
    direct_parent_summary="unknown"
  fi
  local wrapper_start_fingerprint direct_parent_start_fingerprint
  wrapper_start_fingerprint="$(process_start_fingerprint "$$")"
  direct_parent_start_fingerprint="$(process_start_fingerprint "$direct_parent_pid")"

  local loop_parent_pid loop_parent_comm loop_parent_summary loop_parent_override
  if details="$(parent_shell_details)"; then
    IFS=$'\t' read -r loop_parent_pid loop_parent_comm loop_parent_summary loop_parent_override <<<"$details"
  else
    loop_parent_pid="unknown"
    loop_parent_comm="unknown"
    loop_parent_summary="unknown"
    loop_parent_override="0"
  fi
  local loop_parent_start_fingerprint
  loop_parent_start_fingerprint="$(process_start_fingerprint "$loop_parent_pid")"

  log_line "INFO" "$(cycle_start_log_message "$direct_parent_pid" "$direct_parent_comm" "$direct_parent_start_fingerprint" "$loop_parent_pid" "$loop_parent_comm" "$loop_parent_start_fingerprint" "$loop_parent_override" "$wrapper_start_fingerprint")"
  automation_record_cycle_start || log_line "WARN" "automation.run_record.start_failed path=$(shell_quote "${RUN_AUTOMATION_RECORD_FILE:-unknown}")"
  precontact_backup_machine_preflight_or_exit
  resolve_issue_fix_next_or_exit
  lattice_init_and_doctor_or_exit
  lattice_record_cycle_start
  start_run_mark_heartbeat
  check_disk_space_preflight
  if [[ "$STARTUP_ANOMALY_GATE" == "1" ]]; then
    log_line "WARN" "startup_anomaly.gate status=active reasons=$(shell_quote "${STARTUP_ANOMALY_REASONS:-unknown}") force_upkeeper=$CODEX_STARTUP_ANOMALY_FORCE_UPKEEPER action=block_normal_selection_until_upkeeper_suite_checked"
    if ! write_startup_anomaly_gate_state "unresolved" "active_at_startup"; then
      finish_cycle 7 STARTUP_ANOMALY_STATE_UNWRITABLE ERROR "codex_exec_started=0"
    fi
    enforce_startup_anomaly_gate_target_or_exit
  fi

  enforce_primary_quota_block_marker
  ensure_file_manifest_for_selection

  local quota_json
  quota_json="$(quota_state_json)"

  local before_error before_ts before_source before_model_hint before_selection before_matching_snapshot_count before_snapshot_is_current
  local before_snapshot_age_seconds before_primary_reset_age_seconds before_secondary_reset_age_seconds before_snapshot_stale_after_reset
  local before_primary_reset_expired before_secondary_reset_expired before_primary_bucket_current before_secondary_bucket_current
  local before_primary_used before_primary_window before_primary_reset
  local before_secondary_used before_secondary_window before_secondary_reset
  local before_plan_type before_limit_id before_limit_name
  local before_projected_primary_delta before_projected_secondary_delta before_projected_basis
  local primary_used primary_window primary_reset
  local secondary_used secondary_window secondary_reset
  local plan_type limit_id limit_name
  local expected_quota_identity quota_identity_status quota_identity_guardrail_decision="allow"
  local projected_primary_delta projected_secondary_delta projected_basis
  local primary_left secondary_left
  local five_hour_threshold
  local primary_projected_used secondary_projected_used
  local primary_projected_left secondary_projected_left
  local primary_guardrail_decision="defer" secondary_guardrail_decision="defer"

  eval "$(quota_json_assignments "$quota_json" before)"
  if [[ "$before_error" == "no_rate_limit_snapshot_found" ]]; then
    die "no Codex rate-limit snapshot found under $CODEX_HOME_DIR/sessions; run a normal Codex session first or check CODEX_HOME"
  fi
  if [[ "$before_error" == "interrupted" ]]; then
    log_line "WARN" "quota snapshot scan interrupted by operator before cycle start completed"
    finish_cycle 130 QUOTA_SCAN_INTERRUPTED WARN "phase=before_start"
  fi

  primary_used="$before_primary_used"
  primary_window="$before_primary_window"
  primary_reset="$before_primary_reset"
  secondary_used="$before_secondary_used"
  secondary_window="$before_secondary_window"
  secondary_reset="$before_secondary_reset"
  plan_type="$before_plan_type"
  limit_id="$before_limit_id"
  limit_name="$before_limit_name"
  expected_quota_identity="$(quota_expected_identity_for_model "$CODEX_MODEL")"
  quota_identity_status="$(quota_identity_status_for_model "$CODEX_MODEL" "$limit_id" "$limit_name")"
  projected_primary_delta="$before_projected_primary_delta"
  projected_secondary_delta="$before_projected_secondary_delta"
  projected_basis="$before_projected_basis"
  five_hour_threshold="$(quota_5h_stop_percent_for_model "$CODEX_MODEL")"
  week_threshold="$(quota_week_stop_percent_for_model "$CODEX_MODEL")"
  week_buffer="$(quota_week_stop_buffer_percent_for_model "$CODEX_MODEL")"

  primary_left="$(awk -v used="$primary_used" 'BEGIN { printf "%.1f", 100 - used }')"
  secondary_left="$(awk -v used="$secondary_used" 'BEGIN { printf "%.1f", 100 - used }')"
  primary_projected_used="$(awk -v current="$primary_used" -v delta="$projected_primary_delta" 'BEGIN { printf "%.1f", current + delta }')"
  secondary_projected_used="$(awk -v current="$secondary_used" -v delta="$projected_secondary_delta" 'BEGIN { printf "%.1f", current + delta }')"
  primary_projected_left="$(awk -v used="$primary_projected_used" 'BEGIN { printf "%.1f", 100 - used }')"
  secondary_projected_left="$(awk -v used="$secondary_projected_used" 'BEGIN { printf "%.1f", 100 - used }')"

  if [[ "$before_selection" == "exact_model" ]]; then
    primary_guardrail_decision="$(quota_bucket_decision "$before_primary_bucket_current" "$primary_projected_left" "$five_hour_threshold")"
    secondary_guardrail_decision="$(quota_bucket_decision "$before_secondary_bucket_current" "$secondary_projected_left" "$week_threshold")"
    if ! quota_identity_allows_pre_run "$CODEX_MODEL" "$limit_id" "$limit_name"; then
      quota_identity_guardrail_decision="stop"
    fi
  fi

  log_line "INFO" "quota.current execution_origin=$CODEX_EXECUTION_ORIGIN target_model=$CODEX_MODEL snapshot_selection=$before_selection snapshot_current=$before_snapshot_is_current snapshot_stale_after_reset=$before_snapshot_stale_after_reset primary_reset_expired=$before_primary_reset_expired secondary_reset_expired=$before_secondary_reset_expired primary_bucket_current=$before_primary_bucket_current secondary_bucket_current=$before_secondary_bucket_current matching_snapshot_count=$before_matching_snapshot_count expected_quota_identity=$expected_quota_identity quota_identity_status=$quota_identity_status$(quota_hashed_log_field limit_id "$limit_id")$(quota_hashed_log_field limit_name "$limit_name")$(quota_hashed_path_log_field source "$before_source")$(quota_sensitive_log_field limit_id "$limit_id")$(quota_sensitive_log_field limit_name "$limit_name")$(quota_sensitive_log_field plan_type "$plan_type")$(quota_sensitive_log_field source "$before_source")$(quota_sensitive_log_field snapshot_model_hint "$before_model_hint")$(quota_sensitive_log_field event_timestamp "$before_ts")$(quota_sensitive_log_field snapshot_age_seconds "$before_snapshot_age_seconds")$(quota_sensitive_log_field primary_used "${primary_used}%")$(quota_sensitive_log_field primary_left "${primary_left}%")$(quota_sensitive_log_field primary_window "${primary_window}m")$(quota_sensitive_log_field primary_reset "$(format_epoch_local "$primary_reset")")$(quota_sensitive_log_field primary_reset_age_seconds "$before_primary_reset_age_seconds")$(quota_sensitive_log_field secondary_used "${secondary_used}%")$(quota_sensitive_log_field secondary_left "${secondary_left}%")$(quota_sensitive_log_field secondary_window "${secondary_window}m")$(quota_sensitive_log_field secondary_reset "$(format_epoch_local "$secondary_reset")")$(quota_sensitive_log_field secondary_reset_age_seconds "$before_secondary_reset_age_seconds")"
  log_line "INFO" "quota.projection execution_origin=$CODEX_EXECUTION_ORIGIN target_model=$CODEX_MODEL basis=$projected_basis expected_quota_identity=$expected_quota_identity quota_identity_status=$quota_identity_status primary_decision=$primary_guardrail_decision secondary_decision=$secondary_guardrail_decision$(quota_sensitive_log_field projected_primary_delta_used "${projected_primary_delta}%")$(quota_sensitive_log_field projected_primary_used "${primary_projected_used}%")$(quota_sensitive_log_field projected_primary_left "${primary_projected_left}%")$(quota_sensitive_log_field projected_secondary_delta_used "${projected_secondary_delta}%")$(quota_sensitive_log_field projected_secondary_used "${secondary_projected_used}%")$(quota_sensitive_log_field projected_secondary_left "${secondary_projected_left}%")$(quota_sensitive_log_field left_thresholds "${five_hour_threshold}%/${week_threshold}%")$(quota_sensitive_log_field weekly_base_threshold "${CODEX_WEEK_STOP_PERCENT}%")$(quota_sensitive_log_field weekly_buffer "${week_buffer}%")"

  if [[ "$before_selection" != "exact_model" ]]; then
    log_line "WARN" "quota.current target_model=$CODEX_MODEL using snapshot_selection=$before_selection$(quota_sensitive_log_field snapshot_model_hint "$before_model_hint")"
  fi

  local should_stop=0
  local stop_reason=""
  if [[ "$before_selection" == "exact_model" ]]; then
    if [[ "$quota_identity_guardrail_decision" == "stop" ]]; then
      should_stop=1
      stop_reason="unsafe Spark quota identity ${quota_identity_status}; expected ${expected_quota_identity}"
      log_line "WARN" "quota.identity_guardrail target_model=$CODEX_MODEL decision=stop expected_quota_identity=$expected_quota_identity quota_identity_status=$quota_identity_status$(quota_hashed_log_field limit_id "$limit_id")$(quota_hashed_log_field limit_name "$limit_name")$(quota_hashed_path_log_field source "$before_source")$(quota_sensitive_log_field limit_id "$limit_id")$(quota_sensitive_log_field limit_name "$limit_name")$(quota_sensitive_log_field source "$before_source")"
    fi
    if [[ "$primary_guardrail_decision" == "stop" ]]; then
      should_stop=1
      if [[ -n "$stop_reason" ]]; then
        stop_reason="$stop_reason; "
      fi
      stop_reason="${stop_reason}projected 5-hour left ${primary_projected_left}% <= ${five_hour_threshold}%"
    fi
    if [[ "$secondary_guardrail_decision" == "stop" ]]; then
      should_stop=1
      if [[ -n "$stop_reason" ]]; then
        stop_reason="$stop_reason; "
      fi
      stop_reason="${stop_reason}projected weekly left ${secondary_projected_left}% <= ${week_threshold}% (base ${CODEX_WEEK_STOP_PERCENT}% + buffer ${week_buffer}%)"
    fi
    if [[ "$primary_guardrail_decision" == "defer" && "$secondary_guardrail_decision" == "defer" ]]; then
      should_stop=1
      if [[ -n "$stop_reason" ]]; then
