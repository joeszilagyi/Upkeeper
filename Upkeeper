    fi
  fi
  primary_failure_classification="none"
  log_line "INFO" "cycle.summary execution_origin=$CODEX_EXECUTION_ORIGIN model=$CODEX_MODEL observed_primary_delta=$observed_primary_delta observed_secondary_delta=$observed_secondary_delta observed_delta_status=$observed_delta_status status_marker=${status_marker:-missing} status_marker_source=$status_marker_source session_end_state=$session_end_state agent_messages=$primary_session_agent_message_count tool_calls=$primary_session_tool_call_count tool_results=$primary_session_tool_result_count task_complete_last_agent_message=$primary_session_task_complete_last_agent_message codex_exit=$codex_exit"
  log_review_report_summary "$last_message_file" "${status_marker:-missing}" "$codex_exit"
  enforce_startup_anomaly_changed_paths
  record_startup_anomaly_gate_review "$last_message_file" "${status_marker:-missing}" "$codex_exit"
  tool_failure_queue_finalize_run "${RUN_SELECTED_REVIEW_PATH:-}" "${RUN_TRANSCRIPT_FILE:-}" "$codex_exit" "${status_marker:-missing}"

  if [[ "$after_selection" == "exact_model" ]]; then
    if [[ "$after_primary_guardrail_decision" == "stop" ]]; then
      post_run_should_stop=1
      post_run_stop_reason="post-run 5-hour left ${after_primary_left}% <= ${five_hour_threshold}%"
    fi
    if [[ "$after_secondary_guardrail_decision" == "stop" ]]; then
      post_run_should_stop=1
      if [[ -n "$post_run_stop_reason" ]]; then
        post_run_stop_reason="$post_run_stop_reason; "
      fi
      post_run_stop_reason="${post_run_stop_reason}post-run weekly left ${after_secondary_left}% <= ${week_threshold}% (base ${CODEX_WEEK_STOP_PERCENT}% + buffer ${week_buffer}%)"
    fi
    if [[ "$after_primary_guardrail_decision" == "defer" && "$after_secondary_guardrail_decision" == "defer" ]]; then
      log_line "WARN" "quota.guardrails phase=after_run target_model=$CODEX_MODEL deferred reason=stale_snapshot_after_reset snapshot_current=$after_snapshot_is_current snapshot_stale_after_reset=${after_snapshot_stale_after_reset:-unknown} primary_bucket_current=${after_primary_bucket_current:-unknown} secondary_bucket_current=${after_secondary_bucket_current:-unknown} primary_reset=$(format_epoch_local "$after_primary_reset") primary_reset_age_seconds=${after_primary_reset_age_seconds:-unknown} secondary_reset=$(format_epoch_local "$after_secondary_reset") secondary_reset_age_seconds=${after_secondary_reset_age_seconds:-unknown}"
    elif [[ "$after_primary_guardrail_decision" == "defer" || "$after_secondary_guardrail_decision" == "defer" ]]; then
      log_line "WARN" "quota.guardrails phase=after_run target_model=$CODEX_MODEL partial_decision primary_decision=$after_primary_guardrail_decision secondary_decision=$after_secondary_guardrail_decision primary_bucket_current=${after_primary_bucket_current:-unknown} secondary_bucket_current=${after_secondary_bucket_current:-unknown} primary_reset_expired=${after_primary_reset_expired:-unknown} secondary_reset_expired=${after_secondary_reset_expired:-unknown}"
    fi
  fi

  if [[ "$post_run_should_stop" -eq 1 ]]; then
    if [[ "$codex_exit" -ne 0 ]]; then
      ensure_codex_session_store_writable_or_exit "after_run" "1"
      ensure_codex_arg0_tmp_clean_or_exit "after_run" "1"
      ensure_codex_bwrap_tmp_writable_or_exit "after_run" "1"
    fi
    if [[ "$codex_exit" -ne 0 && -z "$status_marker" && "$session_end_state" == "no_agent_message" ]]; then
      primary_failure_classification="PRIMARY_NO_AGENT_MESSAGE_AFTER_QUOTA_EXHAUSTION"
      log_line "WARN" "primary.failure_classification classification=$primary_failure_classification phase=after_run codex_exit=$codex_exit status_marker=missing session_end_state=$session_end_state agent_messages=$primary_session_agent_message_count tool_calls=$primary_session_tool_call_count quota_identity_changed=$quota_session_identity_changed before_limit_id=${limit_id:-unknown} after_limit_id=${after_limit_id:-unknown} session_limit_id=$primary_session_last_rate_limit_limit_id $(quota_transition_fields "$primary_used" "$primary_left" "$secondary_used" "$secondary_left" "$after_primary" "$after_primary_left" "$after_secondary" "$after_secondary_left") observed_delta_status=$observed_delta_status rate_limit_reached_type=$primary_session_last_rate_limit_reached_type"
      log_line "WARN" "primary.no_agent_quota_exhausted classification=$primary_failure_classification phase=after_run codex_exit=$codex_exit status_marker=missing session_end_state=$session_end_state session_source=${after_source:-unknown} quota_identity_changed=$quota_session_identity_changed before_limit_id=${limit_id:-unknown} after_limit_id=${after_limit_id:-unknown} session_limit_id=$primary_session_last_rate_limit_limit_id before_limit_name=$(shell_quote "${limit_name:-unknown}") after_limit_name=$(shell_quote "${after_limit_name:-unknown}") session_limit_name=$(shell_quote "$primary_session_last_rate_limit_limit_name") session_primary_used=${primary_session_last_rate_limit_primary_used_percent}% session_secondary_used=${primary_session_last_rate_limit_secondary_used_percent}% $(quota_transition_fields "$primary_used" "$primary_left" "$secondary_used" "$secondary_left" "$after_primary" "$after_primary_left" "$after_secondary" "$after_secondary_left") observed_delta_status=$observed_delta_status fallback_child_id=pending"
      write_primary_quota_blocked_marker "$post_run_stop_reason codex_exit=$codex_exit status_marker=missing session_end_state=$session_end_state classification=$primary_failure_classification" "after_run"
    fi
    if [[ "$CODEX_ATTEMPT_ROLE" == "primary" && "$CODEX_FALLBACK_ON_PRIMARY_QUOTA" == "1" ]] && fallback_available; then
      local fallback_exit=0
      run_fallback_cycle "primary_quota_after_run" "$post_run_stop_reason codex_exit=$codex_exit status_marker=${status_marker:-missing} session_end_state=$session_end_state classification=$primary_failure_classification" || fallback_exit=$?
      if [[ "$primary_failure_classification" == "PRIMARY_NO_AGENT_MESSAGE_AFTER_QUOTA_EXHAUSTION" ]]; then
        local fallback_child_id fallback_child_marker
        fallback_child_id="$(read_artifact_or_unknown "$CODEX_POSTMORTEM_DIR/$CYCLE_ID/screen/current-child-cycle-id.txt")"
        fallback_child_marker="$(json_field "$(while_marker_analysis_json "${FALLBACK_SCREEN_TRANSCRIPT_PATH:-}")" '.accepted_marker')"
        [[ -n "$fallback_child_marker" ]] || fallback_child_marker="missing"
        log_line "INFO" "primary.no_agent_quota_exhausted.fallback child_exit=$fallback_exit fallback_child_id=$fallback_child_id fallback_child_marker=$fallback_child_marker fallback_screen_session=${FALLBACK_SCREEN_SESSION_NAME:-none}"
      fi
      finish_cycle "$fallback_exit" FALLBACK_CHAIN_EXIT INFO "trigger=primary_quota_after_run final_exit=$fallback_exit target_model=$CODEX_FALLBACK_MODEL postmortem_status=$POSTMORTEM_SEQUENCE_STATUS report_path=${POSTMORTEM_REPORT_PATH:-none}"
    fi
    log_line "WARN" "quota.stop phase=after_run reason=\"$post_run_stop_reason\" codex_exit=$codex_exit status_marker=${status_marker:-missing}"
    if stop_parent_loop; then
      guardrail_stop_exit_code="$CODEX_GUARDRAIL_STOP_EXIT_CODE"
      guardrail_stop_reason="QUOTA_GUARDRAIL_STOP_AFTER_RUN"
      if [[ "${PARENT_LOOP_STOP_OUTCOME:-}" == skipped_* ]]; then
        if [[ "$CODEX_GUARDRAIL_STOP_EXIT_CODE" == "0" ]]; then
          guardrail_stop_exit_code="$CODEX_PARENT_STOP_SKIPPED_EXIT_CODE"
        fi
        guardrail_stop_reason="QUOTA_GUARDRAIL_STOP_PARENT_SKIPPED_AFTER_RUN"
      fi
      finish_cycle "$guardrail_stop_exit_code" "$guardrail_stop_reason" INFO "status_marker=${status_marker:-missing} codex_exit=$codex_exit execution_origin=$CODEX_EXECUTION_ORIGIN parent_stop_outcome=${PARENT_LOOP_STOP_OUTCOME:-unknown}"
    fi
    log_line "ERROR" "cycle.stop failed to confirm parent loop termination after run"
    finish_cycle 4 QUOTA_GUARDRAIL_STOP_FAILED_AFTER_RUN ERROR "status_marker=${status_marker:-missing} codex_exit=$codex_exit"
  fi

  case "$status_marker" in
    WORK_DONE)
      finish_cycle 0 WORK_DONE INFO "codex_exit=$codex_exit"
      ;;
    NO_BACKEND_TASK)
      if [[ "$DIRTY_PATH_COUNT" -gt 0 ]]; then
        if [[ "$CODEX_ATTEMPT_ROLE" == "primary" && "$CODEX_FALLBACK_ON_DIRTY_NO_BACKEND_TASK" == "1" ]] && fallback_available; then
          local fallback_exit=0
          run_fallback_cycle "dirty_no_backend_task" "dirty_paths=$DIRTY_PATH_COUNT tracked_modified_paths=$TRACKED_MODIFIED_PATH_COUNT untracked_paths=$UNTRACKED_PATH_COUNT" || fallback_exit=$?
          finish_cycle "$fallback_exit" FALLBACK_CHAIN_EXIT INFO "trigger=dirty_no_backend_task final_exit=$fallback_exit target_model=$CODEX_FALLBACK_MODEL postmortem_status=$POSTMORTEM_SEQUENCE_STATUS report_path=${POSTMORTEM_REPORT_PATH:-none}"
        fi
        log_line "WARN" "cycle.stop no backend task reported on a dirty worktree; treating this as a soft miss and continuing the outer loop"
        finish_cycle 0 NO_BACKEND_TASK_DIRTY_CONTINUE WARN "dirty_paths=$DIRTY_PATH_COUNT tracked_modified_paths=$TRACKED_MODIFIED_PATH_COUNT untracked_paths=$UNTRACKED_PATH_COUNT codex_exit=$codex_exit"
      fi
      if [[ "$CODEX_CONTINUE_ON_NO_BACKEND_TASK" == "1" ]]; then
        log_line "INFO" "cycle.stop no clear backend task remained; continuing outer loop because CODEX_CONTINUE_ON_NO_BACKEND_TASK=1"
        finish_cycle 0 NO_BACKEND_TASK_CONTINUE INFO "codex_exit=$codex_exit"
      fi
      log_line "INFO" "cycle.stop no clear backend task remained; exiting 5 to stop the outer loop intentionally"
      finish_cycle 5 NO_BACKEND_TASK INFO "stop_outer_loop=1 codex_exit=$codex_exit"
      ;;
    BLOCKED)
      if [[ "$CODEX_ATTEMPT_ROLE" == "primary" && "$CODEX_FALLBACK_ON_BLOCKED" == "1" ]] && fallback_available; then
        local fallback_exit=0
        run_fallback_cycle "blocked" "codex_exit=$codex_exit" || fallback_exit=$?
        finish_cycle "$fallback_exit" FALLBACK_CHAIN_EXIT INFO "trigger=blocked final_exit=$fallback_exit target_model=$CODEX_FALLBACK_MODEL postmortem_status=$POSTMORTEM_SEQUENCE_STATUS report_path=${POSTMORTEM_REPORT_PATH:-none}"
      fi
      finish_cycle 2 BLOCKED WARN "codex_exit=$codex_exit"
      ;;
    *)
      if [[ "$codex_exit" -ne 0 ]]; then
        ensure_codex_session_store_writable_or_exit "after_run" "1"
        ensure_codex_arg0_tmp_clean_or_exit "after_run" "1"
        ensure_codex_bwrap_tmp_writable_or_exit "after_run" "1"
      fi
      if [[ "$codex_exit" -ne 0 && "$session_end_state" == "codex_no_output" ]]; then
        log_line "ERROR" "codex exited non-zero without transcript output"
        finish_cycle 3 CODEX_EXEC_EMPTY_TRANSCRIPT ERROR "codex_exit=$codex_exit transcript=$(shell_quote "$RUN_TRANSCRIPT_FILE") transcript_bytes=$run_transcript_bytes transcript_lines=$run_transcript_lines"
      fi
      if [[ "$CODEX_ATTEMPT_ROLE" == "primary" && "$CODEX_FALLBACK_ON_FAILURE" == "1" ]] && fallback_available; then
        local fallback_exit=0
        run_fallback_cycle "failure" "codex_exit=$codex_exit session_end_state=$session_end_state status_marker=${status_marker:-missing} status_marker_source=$status_marker_source" || fallback_exit=$?
        finish_cycle "$fallback_exit" FALLBACK_CHAIN_EXIT INFO "trigger=failure final_exit=$fallback_exit target_model=$CODEX_FALLBACK_MODEL postmortem_status=$POSTMORTEM_SEQUENCE_STATUS report_path=${POSTMORTEM_REPORT_PATH:-none}"
      fi
      if [[ "$codex_exit" -ne 0 ]]; then
        if [[ "$session_end_state" == turn_aborted:* ]]; then
          log_line "WARN" "codex turn aborted without an UPKEEPER_STATUS marker reason=${session_end_state#turn_aborted:}"
          finish_cycle 6 TURN_ABORTED_WITHOUT_MARKER WARN "reason=${session_end_state#turn_aborted:} codex_exit=$codex_exit"
        fi
        log_line "ERROR" "codex exited non-zero without an UPKEEPER_STATUS marker"
      else
        log_line "ERROR" "missing UPKEEPER_STATUS marker in Codex final response"
      fi
      finish_cycle 3 MISSING_STATUS_MARKER ERROR "codex_exit=$codex_exit session_end_state=$session_end_state status_marker_source=$status_marker_source"
      ;;
  esac
}

# Allow safe sourcing in focused backend validation runs; only execute the wrapper
# when this file is the top-level script entrypoint.
if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
  trap 'handle_wrapper_signal INT' INT
  trap 'handle_wrapper_signal TERM' TERM
  trap 'handle_wrapper_signal HUP' HUP
  main "$@"
fi
