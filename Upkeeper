upkeeper_path_owner_uid() {
  local path="$1"
  local uid=""

  if uid="$(stat -Lc '%u' "$path" 2>/dev/null)"; then
    printf '%s' "$uid"
    return 0
  fi
  if uid="$(stat -f '%u' "$path" 2>/dev/null)"; then
    printf '%s' "$uid"
    return 0
  fi
  if command -v python3 >/dev/null 2>&1; then
    python3 - "$path" <<'PY'
import os
import sys

print(os.lstat(sys.argv[1]).st_uid)
PY
    return $?
  fi

  return 1
}

upkeeper_assert_private_dir() {
  local path="$1"
  local exact_mode="${2:-}"
  local mode="" uid="" current_uid=""

  [[ "$path" == /* ]] || return 1
  [[ -d "$path" ]] || return 1
  [[ ! -L "$path" ]] || return 1

  mode="$(upkeeper_config_path_mode "$path")" || return 1
  uid="$(upkeeper_path_owner_uid "$path")" || return 1
  current_uid="$(id -u)" || return 1
  [[ "$uid" == "$current_uid" ]] || return 1
  (( (8#$mode & 077) == 0 )) || return 1
  if [[ -n "$exact_mode" && "$mode" != "$exact_mode" ]]; then
    return 1
  fi

  return 0
}

upkeeper_assert_private_file() {
  local path="$1"
  local exact_mode="$2"
  local mode="" uid="" current_uid=""

  [[ "$path" == /* ]] || return 1
  [[ -f "$path" ]] || return 1
  [[ ! -L "$path" ]] || return 1

  mode="$(upkeeper_config_path_mode "$path")" || return 1
  uid="$(upkeeper_path_owner_uid "$path")" || return 1
  current_uid="$(id -u)" || return 1
  [[ "$uid" == "$current_uid" ]] || return 1
  (( (8#$mode & 077) == 0 )) || return 1
  [[ "$mode" == "$exact_mode" ]] || return 1

  return 0
}

upkeeper_prepare_fallback_screen_stage_root() {
